<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MBSE Traceability Dashboard</title>
  <style>
    :root {
      /* Brand blues (dark → light) */
      --navy-1: #003057; --navy-2: #004A87; --blue-ng: #0069B0;
      --blue-4: #0082CC; --blue-5: #0099D6; --blue-6: #00A8E0;
      /* Status */
      --pass: #0082CC; --pass-bg: #E8F5EE;
      --fail: #C62828; --fail-bg: #FDECEA;
      --uncovered: #E65100; --uncovered-bg: #FFF3E0;
      --drifted: #F9A825; --drifted-bg: #FFFDE7;
      --manual: #546E7A; --manual-bg: #ECEFF1;
      --orphaned: #0099D6; --orphaned-bg: #E8F4FB;
      --stub: #E65100;
      /* Security severities */
      --sev-critical: #C62828; --sev-high: #E65100; --sev-medium: #F9A825;
      --sev-low: #0099D6; --sev-negligible: #546E7A;
      /* Layout */
      --bg: #F4F7FA; --card: #FFFFFF; --border: #D0E8F8;
      --text: #0D1B2A; --text-muted: #546E7A; --header-bg: #0D1B2A;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: var(--bg); color: var(--text); line-height: 1.5; }
    .container { max-width: 1440px; margin: 0 auto; padding: 16px 20px; }

    /* ---- Hero Header ---- */
    .hero { background: #FFFFFF; color: var(--text); padding: 28px 32px 24px; border-radius: 10px; margin-bottom: 0; border: 1px solid var(--border); box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
    .hero-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-wrap: wrap; gap: 8px; }
    .hero h1 { font-size: 1.5rem; font-weight: 700; color: var(--navy-1); }
    .hero .meta { font-size: 0.8rem; color: var(--text-muted); }
    .hero .pipeline-badge { display: inline-block; padding: 6px 20px; border-radius: 20px; font-weight: 700; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; }
    .pipeline-badge.pass-badge { background: var(--blue-ng); color: #fff; }
    .pipeline-badge.fail-badge { background: var(--fail); color: #fff; }
    .metrics { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 20px; }
    .metric { flex: 1; min-width: 110px; background: var(--navy-1); border-radius: 8px; padding: 14px 12px; text-align: center; color: #fff; }
    .metric .val { font-size: 1.6rem; font-weight: 700; color: #fff; }
    .metric .lbl { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px; color: #D0E8F8; }
    .metric.m-pass { background: var(--blue-ng); }
    .metric.m-fail { background: var(--navy-1); }
    .metric.m-fail .val { color: #EF9A9A; }
    .metric.m-cov { background: var(--blue-4); }
    .metric.m-drift { background: var(--navy-1); }
    .metric.m-drift .val { color: #FFF176; }
    .metric.m-uncov { background: var(--navy-1); }
    .metric.m-uncov .val { color: #FFAB91; }
    .cov-bar { height: 10px; background: #E8F4FB; border-radius: 5px; overflow: hidden; border: 1px solid var(--border); }
    .cov-bar-inner { height: 100%; border-radius: 5px; transition: width 0.4s; }
    .cov-label { display: flex; justify-content: space-between; font-size: 0.75rem; color: var(--text-muted); margin-bottom: 3px; }

    /* ---- Tabs ---- */
    .tab-bar { display: flex; background: var(--card); border-bottom: 2px solid var(--border); border-radius: 10px 10px 0 0; overflow-x: auto; }
    .tab-btn { flex: none; padding: 12px 24px; border: none; background: none; font-size: 0.9rem; font-weight: 600; color: var(--text-muted); cursor: pointer; border-bottom: 3px solid transparent; transition: all 0.2s; white-space: nowrap; }
    .tab-btn:hover { color: var(--text); background: #E8F4FB; }
    .tab-btn.active { color: var(--blue-ng); border-bottom-color: var(--blue-ng); }
    .tab-panel { display: none; background: var(--card); border-radius: 0 0 10px 10px; padding: 24px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
    .tab-panel.active { display: block; }

    /* ---- Shared ---- */
    .badge { display: inline-block; padding: 2px 10px; border-radius: 12px; font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
    .b-pass { background: var(--pass); color: #fff; }
    .b-fail { background: var(--fail); color: #fff; }
    .b-uncovered { background: var(--uncovered); color: #fff; }
    .b-drifted { background: var(--drifted); color: #333; }
    .b-manual { background: var(--manual); color: #fff; }
    .b-orphaned { background: var(--orphaned); color: #fff; }
    .b-stub { background: var(--stub); color: #fff; }
    .filter-row { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 20px; align-items: center; }
    .filter-row label { font-weight: 600; font-size: 0.82rem; }
    .filter-row select, .filter-row input { padding: 6px 10px; border: 1px solid var(--border); border-radius: 6px; font-size: 0.85rem; }
    .filter-row input[type="text"] { min-width: 200px; }
    .empty-state { text-align: center; padding: 60px 20px; color: var(--text-muted); }
    .empty-state .icon { font-size: 3rem; margin-bottom: 12px; }
    .empty-state h3 { margin-bottom: 8px; color: var(--text); }

    /* ---- Tab 1: Traceability Accordion ---- */
    .accordion-header { display: flex; align-items: center; gap: 12px; padding: 8px 16px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted); border-bottom: 2px solid var(--border); margin-bottom: 8px; }
    .ah-expand { width: 12px; }
    .ah-id { min-width: 120px; }
    .ah-title { flex: 1; }
    .ah-bar { width: 80px; text-align: center; }
    .ah-summary { min-width: 100px; text-align: right; }
    .req-card { border: 1px solid #dde3ea; border-radius: 8px; margin-bottom: 10px; overflow: hidden; border-left: 4px solid #dde3ea; background: #fff; }
    .req-card.rc-pass { border-left-color: var(--pass); }
    .req-card.rc-fail { border-left-color: var(--fail); }
    .req-card.rc-uncovered { border-left-color: var(--uncovered); }
    .req-card.rc-drifted { border-left-color: var(--drifted); }
    .req-card.rc-manual { border-left-color: var(--manual); }
    .req-header { display: flex; align-items: center; gap: 12px; padding: 12px 16px; cursor: pointer; user-select: none; transition: background 0.15s; background: #fff; }
    .req-header:hover { background: #f7f8fa; }
    .req-header .arrow { transition: transform 0.2s; font-size: 0.7rem; color: var(--text-muted); }
    .req-header .arrow.open { transform: rotate(90deg); }
    .req-id { font-weight: 700; font-family: monospace; font-size: 0.9rem; min-width: 120px; }
    .req-title { flex: 1; font-size: 0.9rem; }
    .mini-bar { display: flex; width: 80px; height: 8px; border-radius: 4px; overflow: hidden; background: #e9ecef; }
    .mini-bar span { height: 100%; }
    .vm-summary { font-size: 0.75rem; color: var(--text-muted); min-width: 100px; text-align: right; }
    .req-body { display: none; border-top: 1px solid #e9ecef; padding: 0; background: #f9fafb; }
    .req-body.open { display: block; }
    .req-desc { padding: 10px 16px; font-size: 0.85rem; color: var(--text-muted); background: #f9fafb; border-bottom: 1px solid #e9ecef; }
    .vm-row { border-bottom: 1px solid #e9ecef; background: #fff; margin: 0 12px; border-radius: 6px; margin-bottom: 4px; border: 1px solid #e9ecef; }
    .vm-row:last-child { margin-bottom: 8px; }
    .vm-header { display: flex; align-items: center; gap: 12px; padding: 10px 14px; cursor: pointer; font-size: 0.85rem; }
    .vm-header:hover { background: #f7f8fa; border-radius: 6px; }
    .vm-header .arrow { font-size: 0.6rem; color: var(--text-muted); transition: transform 0.2s; }
    .vm-header .arrow.open { transform: rotate(90deg); }
    .vm-id { font-family: monospace; font-weight: 600; min-width: 180px; }
    .vm-method { min-width: 100px; color: var(--text-muted); }
    .vm-feature { font-size: 0.8rem; color: var(--text-muted); flex: 1; text-align: right; font-family: monospace; }
    .vm-criteria { padding: 8px 14px; font-size: 0.82rem; color: var(--text-muted); font-style: italic; border-top: 1px solid #f0f0f0; }
    .scenario-list { display: none; }
    .scenario-list.open { display: block; }
    .scenario-item { padding: 8px 14px; border-top: 1px solid #f0f0f0; }
    .scenario-name { font-weight: 600; font-size: 0.85rem; margin-bottom: 4px; }
    .step { display: flex; gap: 8px; padding: 2px 0 2px 16px; font-size: 0.82rem; font-family: monospace; }
    .step-kw { font-weight: 700; min-width: 50px; }
    .step-kw.given { color: var(--blue-ng); }
    .step-kw.when { color: var(--navy-1); }
    .step-kw.then { color: var(--blue-4); }
    .step-kw.and, .step-kw.but { color: var(--text-muted); }
    .step-text { flex: 1; }
    .step-dur { color: var(--text-muted); font-size: 0.75rem; min-width: 60px; text-align: right; }
    .step-status { min-width: 16px; }
    .step-status.passed::before { content: "\2713"; color: var(--pass); }
    .step-status.failed::before { content: "\2717"; color: var(--fail); }

    /* ---- Tab 2: Security ---- */
    .sev-cards { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 24px; }
    .sev-card { flex: 1; min-width: 120px; border-radius: 8px; padding: 16px; text-align: center; color: #fff; }
    .sev-card .sev-val { font-size: 2rem; font-weight: 700; }
    .sev-card .sev-lbl { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; }
    .sev-critical { background: var(--sev-critical); }
    .sev-high { background: var(--sev-high); }
    .sev-medium { background: var(--sev-medium); color: #333; }
    .sev-low { background: var(--sev-low); }
    .sev-negligible { background: var(--sev-negligible); }
    table.data-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
    table.data-table th { background: var(--header-bg); color: #fff; padding: 10px 12px; text-align: left; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.5px; cursor: pointer; position: sticky; top: 0; }
    table.data-table th:hover { background: var(--navy-1); }
    table.data-table td { padding: 8px 12px; border-bottom: 1px solid var(--border); vertical-align: top; }
    table.data-table tr:hover { background: #E8F4FB; }
    .table-scroll { max-height: 500px; overflow-y: auto; border: 1px solid var(--border); border-radius: 8px; }
    .section-title { font-size: 1.1rem; font-weight: 700; margin: 24px 0 12px; padding-bottom: 8px; border-bottom: 2px solid var(--border); }
    .section-title:first-child { margin-top: 0; }

    /* ---- Tab 3: Gates ---- */
    .gate-cards { display: flex; gap: 20px; flex-wrap: wrap; }
    .gate-card { flex: 1; min-width: 300px; border-radius: 10px; border: 2px solid var(--border); padding: 20px; }
    .gate-card.gate-pass { border-color: var(--pass); }
    .gate-card.gate-fail { border-color: var(--fail); }
    .gate-card .gate-title { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; padding: 12px 16px; margin: -20px -20px 12px; border-radius: 8px 8px 0 0; color: #fff; }
    .gate-card[data-gate="A"] .gate-title { background: var(--blue-ng); }
    .gate-card[data-gate="B"] .gate-title { background: var(--blue-4); }
    .gate-card[data-gate="C"] .gate-title { background: var(--navy-1); }
    .gate-card .gate-name { font-size: 1.1rem; font-weight: 700; }
    .gate-card .gate-desc { font-size: 0.85rem; color: var(--text-muted); margin-bottom: 12px; }
    .gate-item { padding: 8px 12px; border: 1px solid #D0E8F8; border-radius: 6px; margin-bottom: 6px; font-size: 0.85rem; background: #EBF5FB; }
    .gate-item .gi-id { font-family: monospace; font-weight: 600; }
    .gate-item:hover { background: #E8F4FB; border-color: var(--blue-ng); }
    .gate-item .gi-detail { color: var(--text-muted); font-size: 0.8rem; }

    /* ---- Tab 4: Test Execution ---- */
    .test-feature { border: 1px solid var(--border); border-radius: 8px; margin-bottom: 8px; overflow: hidden; }
    .test-feature-header { display: flex; align-items: center; gap: 12px; padding: 12px 16px; cursor: pointer; font-weight: 600; font-size: 0.9rem; }
    .test-feature-header:hover { background: #E8F4FB; }
    .test-feature-header .arrow { font-size: 0.7rem; color: var(--text-muted); transition: transform 0.2s; }
    .test-feature-header .arrow.open { transform: rotate(90deg); }
    .test-feature-header .feat-status { margin-left: auto; }
    .test-feature-header .feat-dur { font-size: 0.8rem; color: var(--text-muted); font-weight: 400; }
    .test-feature-body { display: none; border-top: 1px solid var(--border); }
    .test-feature-body.open { display: block; }
    .test-scenario { padding: 10px 16px 10px 32px; border-bottom: 1px solid #D0E8F8; }
    .test-scenario:last-child { border-bottom: none; }
    .test-scenario-name { font-weight: 600; font-size: 0.85rem; margin-bottom: 6px; display: flex; justify-content: space-between; }

    /* ---- Tab 5: Export ---- */
    .export-actions { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 24px; }
    .btn { padding: 10px 24px; border: none; border-radius: 8px; font-size: 0.9rem; font-weight: 600; cursor: pointer; transition: all 0.2s; }
    .btn-primary { background: var(--blue-ng); color: #fff; }
    .btn-primary:hover { background: var(--navy-2); }
    .btn-secondary { background: #E8F4FB; color: var(--text); border: 1px solid var(--border); }
    .btn-secondary:hover { background: #D0E8F8; }
    .info-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; margin-bottom: 24px; }
    .info-item { padding: 16px; background: #E8F4FB; border-radius: 8px; border: 1px solid var(--border); }
    .info-item .info-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted); margin-bottom: 4px; }
    .info-item .info-value { font-size: 1rem; font-weight: 600; }
    .legend-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 8px; }
    .legend-item { display: flex; align-items: center; gap: 8px; font-size: 0.85rem; }
    .legend-dot { width: 14px; height: 14px; border-radius: 50%; flex-shrink: 0; }

    /* ---- Floating Legend ---- */
    .legend-fab { position: fixed; bottom: 24px; right: 24px; width: 44px; height: 44px; border-radius: 50%; background: var(--navy-1); color: #fff; border: none; font-size: 1.2rem; cursor: pointer; box-shadow: 0 3px 12px rgba(0,0,0,0.25); z-index: 100; display: flex; align-items: center; justify-content: center; transition: transform 0.2s; }
    .legend-fab:hover { transform: scale(1.1); }
    .legend-popup { position: fixed; bottom: 80px; right: 24px; background: #fff; border: 1px solid var(--border); border-radius: 10px; padding: 16px 20px; box-shadow: 0 8px 30px rgba(0,0,0,0.15); z-index: 100; display: none; min-width: 260px; }
    .legend-popup.open { display: block; }
    .legend-popup h4 { margin: 0 0 10px; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted); }
    .legend-popup .legend-item { margin-bottom: 6px; }

    /* ---- Search Highlight ---- */
    mark.search-hl { background: #FFF176; color: var(--text); padding: 0 2px; border-radius: 2px; }

    /* ---- Print ---- */
    @media print {
      .tab-bar { display: none; }
      .tab-panel { display: block !important; page-break-before: always; box-shadow: none; border: none; }
      .tab-panel:first-of-type { page-break-before: auto; }
      .hero { background: #fff !important; }
      .metric { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .filter-row { display: none; }
      .req-body, .scenario-list, .test-feature-body { display: block !important; }
      .req-card, .gate-card, .test-feature { page-break-inside: avoid; }
      .btn { display: none; }
      .legend-fab, .legend-popup { display: none !important; }
    }

    /* ---- Footer ---- */
    .footer { text-align: center; color: var(--text-muted); font-size: 0.75rem; padding: 16px; margin-top: 16px; }
  </style>
</head>
<body>
<div class="container">

  <!-- ======== HERO HEADER ======== -->
  <div class="hero">
    <div class="hero-top">
      <div>
        <h1>MBSE Traceability Dashboard</h1>
        <div class="meta" id="hero-timestamp">Generated: {{ generated_at }}</div>
      </div>
      <span class="pipeline-badge {% if summary.failed == 0 and summary.coverage_percent >= 100 %}pass-badge{% else %}fail-badge{% endif %}">
        Pipeline {% if summary.failed == 0 and summary.coverage_percent >= 100 %}Pass{% else %}Attention Required{% endif %}
      </span>
    </div>
    <div id="hero-summary-sentence" style="font-size:0.95rem;color:var(--text);margin-bottom:16px;line-height:1.7;padding:12px 16px;background:#EBF5FB;border-radius:8px;border-left:4px solid var(--blue-ng)"></div>
    <div class="metrics">
      <div class="metric m-cov">
        <div class="val">{{ "%.0f" | format(summary.coverage_percent) }}%</div>
        <div class="lbl">VC Coverage</div>
      </div>
      <div class="metric">
        <div class="val">{{ summary.total_vms }}</div>
        <div class="lbl">Total VCs</div>
      </div>
      <div class="metric">
        <div class="val">{{ summary.covered_vms }}</div>
        <div class="lbl">Covered</div>
      </div>
      <div class="metric m-pass">
        <div class="val">{{ summary.passed }}</div>
        <div class="lbl">Passed</div>
      </div>
      <div class="metric m-fail">
        <div class="val">{{ summary.failed }}</div>
        <div class="lbl">Failed</div>
      </div>
      <div class="metric m-uncov">
        <div class="val">{{ summary.uncovered_vms }}</div>
        <div class="lbl">Uncovered</div>
      </div>
      <div class="metric m-drift">
        <div class="val">{{ summary.drifted_vms }}</div>
        <div class="lbl">Drifted</div>
      </div>
      <div class="metric">
        <div class="val">{{ summary.manual }}</div>
        <div class="lbl">Manual</div>
      </div>
    </div>
    <div>
      <div class="cov-label">
        <span>Verification Criteria Breakdown</span>
        <span>{{ summary.covered_vms }} / {{ summary.total_vms }} VCs covered</span>
      </div>
      <div class="cov-bar" style="display:flex;height:14px;border-radius:7px;overflow:hidden;border:1px solid var(--border);background:#E8F4FB">
        {% if summary.total_vms > 0 %}
        {% set tw = summary.total_vms %}
        {% if summary.passed > 0 %}<div style="width:{{ (summary.passed/tw*100)|round(1) }}%;background:var(--pass)" title="Passed: {{ summary.passed }}"></div>{% endif %}
        {% if summary.failed > 0 %}<div style="width:{{ (summary.failed/tw*100)|round(1) }}%;background:var(--fail)" title="Failed: {{ summary.failed }}"></div>{% endif %}
        {% if summary.drifted_vms > 0 %}<div style="width:{{ (summary.drifted_vms/tw*100)|round(1) }}%;background:var(--drifted)" title="Drifted: {{ summary.drifted_vms }}"></div>{% endif %}
        {% if summary.uncovered_vms > 0 %}<div style="width:{{ (summary.uncovered_vms/tw*100)|round(1) }}%;background:var(--uncovered)" title="Uncovered: {{ summary.uncovered_vms }}"></div>{% endif %}
        {% if summary.manual > 0 %}<div style="width:{{ (summary.manual/tw*100)|round(1) }}%;background:var(--manual)" title="Manual: {{ summary.manual }}"></div>{% endif %}
        {% endif %}
      </div>
    </div>
  </div>

  <!-- ======== TABS ======== -->
  <nav class="tab-bar">
    <button class="tab-btn active" data-tab="traceability">Traceability Matrix</button>
    <button class="tab-btn" data-tab="gates">Quality Gates</button>
    <button class="tab-btn" data-tab="tests">Test Execution</button>
    <button class="tab-btn" data-tab="security">Cyber</button>
    <button class="tab-btn" data-tab="export">Export &amp; Info</button>
  </nav>

  <!-- ======== TAB 1: TRACEABILITY ======== -->
  <div id="panel-traceability" class="tab-panel active">
    <div class="filter-row">
      <label>Status:</label>
      <select id="f-status"><option value="all">All</option><option value="pass">Passed</option><option value="fail">Failed</option><option value="uncovered">Uncovered</option><option value="drifted">Drifted</option><option value="manual">Manual</option></select>
      <label>Criteria Type:</label>
      <select id="f-method"><option value="all">All</option><option value="Test">Test</option><option value="Demonstration">Demonstration</option><option value="Analysis">Analysis</option><option value="Inspection">Inspection</option></select>
      <label>Search:</label>
      <input type="text" id="f-search" placeholder="Filter by ID, title, or criteria...">
    </div>
    <div class="accordion-header">
      <span class="ah-expand"></span>
      <span class="ah-id">Requirement ID</span>
      <span class="ah-title">Title</span>
      <span class="ah-bar">Coverage</span>
      <span class="ah-summary">VCs</span>
      <button onclick="toggleAllReqs()" class="btn btn-secondary" style="padding:4px 12px;font-size:0.75rem;margin-left:8px" id="btn-expand-all">Expand All</button>
    </div>
    <div id="trace-accordion"></div>
  </div>

  <!-- ======== TAB 2: QUALITY GATES ======== -->
  <div id="panel-gates" class="tab-panel">
    <div id="gates-content"></div>
  </div>

  <!-- ======== TAB 3: TEST EXECUTION ======== -->
  <div id="panel-tests" class="tab-panel">
    <div id="tests-content"></div>
  </div>

  <!-- ======== TAB 4: SECURITY ======== -->
  <div id="panel-security" class="tab-panel">
    <div id="security-content"></div>
  </div>

  <!-- ======== TAB 5: EXPORT & INFO ======== -->
  <div id="panel-export" class="tab-panel">
    <h2 class="section-title" style="margin-top:0">Actions</h2>
    <div class="export-actions">
      <button class="btn btn-primary" onclick="window.print()">Print Report</button>
      <button class="btn btn-secondary" onclick="downloadJSON()">Download JSON</button>
    </div>

    <h2 class="section-title">Pipeline Metadata</h2>
    <div class="info-grid" id="metadata-grid"></div>

    <h2 class="section-title">Report Legend</h2>
    <div class="legend-grid">
      <div class="legend-item"><span class="legend-dot" style="background:var(--pass)"></span> Pass — VM covered, test passed</div>
      <div class="legend-item"><span class="legend-dot" style="background:var(--fail)"></span> Fail — VM covered, test failed</div>
      <div class="legend-item"><span class="legend-dot" style="background:var(--uncovered)"></span> Uncovered — No scenario for this VM</div>
      <div class="legend-item"><span class="legend-dot" style="background:var(--drifted)"></span> Drifted — Criteria changed since baseline</div>
      <div class="legend-item"><span class="legend-dot" style="background:var(--manual)"></span> Manual — Non-test verification method</div>
      <div class="legend-item"><span class="legend-dot" style="background:var(--orphaned)"></span> Orphaned — Test with no matching requirement</div>
    </div>

    <h2 class="section-title">Glossary</h2>
    <div class="info-grid">
      <div class="info-item"><div class="info-label">Verification Criteria (VC)</div><div class="info-value" style="font-weight:400;font-size:0.85rem">A specific technique for verifying a requirement: Test, Demonstration, Analysis, or Inspection (INCOSE ADIT).</div></div>
      <div class="info-item"><div class="info-label">Gate A — Coverage</div><div class="info-value" style="font-weight:400;font-size:0.85rem">Checks every verification criteria has at least one Gherkin scenario. Generates stubs for uncovered VCs.</div></div>
      <div class="info-item"><div class="info-label">Gate B — Drift Detection</div><div class="info-value" style="font-weight:400;font-size:0.85rem">Detects when verification criteria text changes between model versions. Flags affected scenarios for review.</div></div>
      <div class="info-item"><div class="info-label">Gate C — Orphan Detection</div><div class="info-value" style="font-weight:400;font-size:0.85rem">Finds test scenarios that reference requirements or VCs that no longer exist in the model.</div></div>
      <div class="info-item"><div class="info-label">Traceability Baseline</div><div class="info-value" style="font-weight:400;font-size:0.85rem">A snapshot of criteria hashes used by Gate B. Updated explicitly after review, creating an audit trail.</div></div>
      <div class="info-item"><div class="info-label">SBOM</div><div class="info-value" style="font-weight:400;font-size:0.85rem">Software Bill of Materials — a complete inventory of all software components in the deployed artifact.</div></div>
    </div>
  </div>

  <div class="footer">MBSE Traceability Dashboard &mdash; Auto-generated by the product pipeline</div>

  <!-- Floating Legend -->
  <button class="legend-fab" onclick="document.getElementById('legend-popup').classList.toggle('open')" title="Status Legend">?</button>
  <div class="legend-popup" id="legend-popup">
    <h4>Status Legend</h4>
    <div class="legend-item"><span class="legend-dot" style="background:var(--pass)"></span> Pass — VC covered, test passed</div>
    <div class="legend-item"><span class="legend-dot" style="background:var(--fail)"></span> Fail — VC covered, test failed</div>
    <div class="legend-item"><span class="legend-dot" style="background:var(--uncovered)"></span> Uncovered — No scenario written</div>
    <div class="legend-item"><span class="legend-dot" style="background:var(--drifted)"></span> Drifted — Criteria changed</div>
    <div class="legend-item"><span class="legend-dot" style="background:var(--manual)"></span> Manual — Analysis / Inspection</div>
    <div class="legend-item"><span class="legend-dot" style="background:var(--orphaned)"></span> Orphaned — Deleted requirement</div>
  </div>
</div>

<!-- ======== DATA INJECTION ======== -->
<script>
const REPORT = {{ report_json }};
const REQUIREMENTS = {{ requirements_json }};
const BEHAVE = {{ behave_json }};
const TRACEABILITY = {{ traceability_json }};
const SBOM = {{ sbom_json }};
const GRYPE = {{ grype_json }};
</script>

<script>
/* ================================================================
   TAB NAVIGATION
   ================================================================ */
document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('panel-' + btn.dataset.tab).classList.add('active');
  });
});

/* ================================================================
   HELPERS
   ================================================================ */
function esc(s) { const d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }
const VALID_STATUSES = ['pass','fail','uncovered','drifted','manual','orphaned','stub'];
const STATUS_ICONS = {pass:'\u2713',fail:'\u2717',uncovered:'\u2014',drifted:'\u21BB',manual:'\u270B',orphaned:'?',stub:'\u2014'};
function badgeFor(status) {
  const cls = VALID_STATUSES.includes(status) ? status : 'manual';
  const icon = STATUS_ICONS[cls] || '';
  return '<span class="badge b-' + cls + '">' + icon + ' ' + esc(status) + '</span>';
}
function fmtDur(s) { return s != null ? (s < 1 ? (s*1000).toFixed(0) + 'ms' : s.toFixed(2) + 's') : ''; }
/* Word-level diff for drifted criteria */
function wordDiff(oldText, newText) {
  if (!oldText || !newText) return null;
  const oldWords = oldText.split(/(\s+)/);
  const newWords = newText.split(/(\s+)/);
  /* Simple LCS-based word diff */
  const m = oldWords.length, n = newWords.length;
  const dp = Array.from({length: m+1}, () => new Array(n+1).fill(0));
  for (let i = 1; i <= m; i++)
    for (let j = 1; j <= n; j++)
      dp[i][j] = oldWords[i-1] === newWords[j-1] ? dp[i-1][j-1]+1 : Math.max(dp[i-1][j], dp[i][j-1]);
  /* Backtrack to build diff */
  const result = [];
  let i = m, j = n;
  while (i > 0 || j > 0) {
    if (i > 0 && j > 0 && oldWords[i-1] === newWords[j-1]) {
      result.unshift({type:'same', text:oldWords[i-1]});
      i--; j--;
    } else if (j > 0 && (i === 0 || dp[i][j-1] >= dp[i-1][j])) {
      result.unshift({type:'add', text:newWords[j-1]});
      j--;
    } else {
      result.unshift({type:'del', text:oldWords[i-1]});
      i--;
    }
  }
  return result;
}
function renderDiff(diffTokens) {
  return diffTokens.map(t => {
    if (t.type === 'add') return '<span style="background:#d4edda;color:#155724;padding:1px 2px;border-radius:2px;text-decoration:none">' + esc(t.text) + '</span>';
    if (t.type === 'del') return '<span style="background:#f8d7da;color:#721c24;padding:1px 2px;border-radius:2px;text-decoration:line-through">' + esc(t.text) + '</span>';
    return esc(t.text);
  }).join('');
}

/* Build lookup: vmId -> gate B item for drift data */
const driftLookup = {};
if (TRACEABILITY && TRACEABILITY.gate_b && TRACEABILITY.gate_b.items) {
  TRACEABILITY.gate_b.items.forEach(item => {
    const id = item.verificationMethodId || item.vm_id || '';
    if (id) driftLookup[id] = item;
  });
}

function fmtDate(iso) {
  if (!iso) return '\u2014';
  try {
    const d = new Date(iso);
    if (isNaN(d)) return iso;
    const now = new Date();
    const diffMs = now - d;
    if (diffMs > 0 && diffMs < 86400000) {
      const mins = Math.floor(diffMs / 60000);
      if (mins < 1) return 'Just now';
      if (mins < 60) return mins + ' minute' + (mins > 1 ? 's' : '') + ' ago';
      const hrs = Math.floor(mins / 60);
      return hrs + ' hour' + (hrs > 1 ? 's' : '') + ' ago';
    }
    return d.toLocaleDateString(undefined, {year:'numeric',month:'long',day:'numeric'}) + ' at ' + d.toLocaleTimeString(undefined, {hour:'2-digit',minute:'2-digit'});
  } catch(e) { return iso; }
}

/* Build a lookup: reqId -> full requirement object from REQUIREMENTS */
const reqLookup = {};
if (REQUIREMENTS && REQUIREMENTS.requirements) {
  REQUIREMENTS.requirements.forEach(r => { reqLookup[r.requirementId] = r; });
}

/* Build behave lookup: feature name -> feature object with full steps */
const behaveLookup = {};
const behaveFeatures = Array.isArray(BEHAVE) ? BEHAVE : (BEHAVE && BEHAVE.features ? BEHAVE.features : []);
behaveFeatures.forEach(f => {
  const tags = (f.tags || []).map(t => typeof t === 'string' ? t : (t.name || ''));
  /* Index by feature name and by REQ/VM tags */
  behaveLookup[f.name] = f;
  tags.forEach(tag => {
    const clean = tag.replace(/^@/, '');
    behaveLookup[clean] = f;
  });
});

/* Find behave scenarios matching a given VM ID */
function findScenariosForVM(vmId, reqId, reportRow) {
  /* Don't look for scenarios if this VC is uncovered or drifted — there aren't real ones */
  if (reportRow && (reportRow.status === 'uncovered' || reportRow.status === 'drifted')) {
    return [];
  }
  const results = [];
  behaveFeatures.forEach(feat => {
    const fTags = (feat.tags || []).map(t => (typeof t === 'string' ? t : (t.name || '')).replace(/^@/, ''));
    (feat.elements || []).forEach(el => {
      if (el.keyword === 'Background') return;
      const sTags = (el.tags || []).map(t => (typeof t === 'string' ? t : (t.name || '')).replace(/^@/, ''));
      const allTags = [...fTags, ...sTags];
      const hasVM = allTags.some(t => t.replace(/^VM[:\-_]/i, '') === vmId);
      const hasReq = allTags.some(t => t.replace(/^REQ[:\-_]/i, '') === reqId);
      /* Match by: (1) explicit VM tag, or (2) scenario name from report */
      if (hasVM) {
        results.push({ scenario: el, featureName: feat.name, featureFile: feat.location || feat.filename || '' });
      } else if (hasReq && reportRow && reportRow.scenario_name && el.name === reportRow.scenario_name) {
        results.push({ scenario: el, featureName: feat.name, featureFile: feat.location || feat.filename || '' });
      }
    });
  });
  /* Last resort: req-level match when report confirms a test result exists */
  if (results.length === 0 && reportRow && reportRow.status === 'pass') {
    behaveFeatures.forEach(feat => {
      const fTags = (feat.tags || []).map(t => (typeof t === 'string' ? t : (t.name || '')).replace(/^@/, ''));
      const hasReq = fTags.some(t => t.replace(/^REQ[:\-_]/i, '') === reqId);
      if (hasReq) {
        (feat.elements || []).forEach(el => {
          if (el.keyword === 'Background') return;
          results.push({ scenario: el, featureName: feat.name, featureFile: feat.location || feat.filename || '' });
        });
      }
    });
  }
  return results;
}

/* ================================================================
   TAB 1: TRACEABILITY MATRIX
   ================================================================ */
function renderTraceability() {
  const container = document.getElementById('trace-accordion');
  if (!REPORT || !REPORT.requirements || !REPORT.requirements.length) {
    container.innerHTML = '<div class="empty-state"><div class="icon">&#128203;</div><h3>No Requirements Data</h3><p>No traceability data is available for this report.</p></div>';
    return;
  }
  /* Group report rows by requirement_id */
  const grouped = {};
  const reqOrder = [];
  REPORT.requirements.forEach(row => {
    if (!grouped[row.requirement_id]) { grouped[row.requirement_id] = []; reqOrder.push(row.requirement_id); }
    grouped[row.requirement_id].push(row);
  });

  let html = '';
  reqOrder.forEach(reqId => {
    const rows = grouped[reqId];
    const req = reqLookup[reqId] || {};
    const title = rows[0].title || req.title || '';
    const desc = req.description || '';
    const satisfiedBy = (req.satisfiedBy || []).join(', ');
    const tracesTo = (req.tracesTo || []).join(', ');

    /* Mini bar */
    const counts = { pass: 0, fail: 0, uncovered: 0, drifted: 0, manual: 0 };
    rows.forEach(r => { counts[r.status] = (counts[r.status] || 0) + 1; });
    const total = rows.length;
    let miniBar = '<div class="mini-bar">';
    ['pass','fail','uncovered','drifted','manual'].forEach(s => {
      if (counts[s]) miniBar += '<span style="width:' + (counts[s]/total*100) + '%;background:var(--' + s + ')"></span>';
    });
    miniBar += '</div>';

    const vmSummary = rows.length + ' VC' + (rows.length > 1 ? 's' : '');

    /* Worst-status determines the card's left-border color */
    const STATUS_PRIORITY = ['fail','drifted','uncovered','manual','pass'];
    let worstStatus = 'pass';
    rows.forEach(r => {
      if (STATUS_PRIORITY.indexOf(r.status) < STATUS_PRIORITY.indexOf(worstStatus)) worstStatus = r.status;
    });

    html += '<div class="req-card rc-' + worstStatus + '" data-req="' + reqId + '">';
    html += '<div class="req-header" onclick="toggleReq(this)">';
    html += '<span class="arrow">&#9654;</span>';
    html += '<span class="req-id">' + esc(reqId) + '</span>';
    html += '<span class="req-title">' + esc(title) + '</span>';
    html += miniBar;
    html += '<span class="vm-summary">' + vmSummary + '</span>';
    html += '</div>';

    html += '<div class="req-body">';
    if (desc) html += '<div class="req-desc">' + esc(desc);
    if (satisfiedBy) html += '<br><strong>Satisfied By:</strong> ' + esc(satisfiedBy);
    if (tracesTo) html += '<br><strong>Traces To:</strong> ' + esc(tracesTo);
    if (desc) html += '</div>';

    rows.forEach(row => {
      const vmId = row.vm_id || '';
      const scenarios = findScenariosForVM(vmId, reqId, row);

      html += '<div class="vm-row" data-status="' + row.status + '" data-method="' + esc(row.method) + '">';
      html += '<div class="vm-header" onclick="toggleVM(this)">';
      html += '<span class="arrow">&#9654;</span>';
      html += '<span class="vm-id">' + esc(vmId || reqId) + '</span>';
      html += '<span class="vm-method">' + esc(row.method) + '</span>';
      html += badgeFor(row.status);
      if (scenarios.length > 0) html += '<span style="font-size:0.75rem;color:var(--text-muted);margin-left:auto">(' + scenarios.length + ' scenario' + (scenarios.length > 1 ? 's' : '') + ')</span>';
      html += '<span class="vm-feature">' + esc(row.feature_file || '') + '</span>';
      html += '</div>';

      /* Criteria display — show diff for drifted VCs */
      if (row.status === 'drifted' && driftLookup[vmId]) {
        const drift = driftLookup[vmId];
        if (drift.oldCriteria && drift.newCriteria) {
          const diff = wordDiff(drift.oldCriteria, drift.newCriteria);
          html += '<div class="vm-criteria" style="font-style:normal">';
          html += '<div style="font-size:0.75rem;font-weight:600;color:var(--text-muted);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px">Criteria Changed</div>';
          html += '<div style="font-size:0.85rem;line-height:1.6">' + renderDiff(diff) + '</div>';
          html += '</div>';
        } else {
          if (row.criteria) html += '<div class="vm-criteria">' + esc(row.criteria) + '</div>';
        }
      } else if (row.criteria) {
        html += '<div class="vm-criteria">' + esc(row.criteria) + '</div>';
      }

      /* Action hint for non-pass statuses */
      const ACTION_HINTS = {
        uncovered: 'Action: Write a Gherkin scenario for this verification criteria, then re-run the pipeline.',
        drifted: 'Action: Review the changes above, update the scenario if needed, remove @REVIEW_REQUIRED, and run --update-baseline.',
        fail: 'Action: Investigate the test failure below. Fix the product code or update the scenario.',
      };
      if (ACTION_HINTS[row.status]) {
        html += '<div style="padding:8px 14px;font-size:0.82rem;color:var(--' + row.status + ');border-top:1px solid #f0f0f0">' + ACTION_HINTS[row.status] + '</div>';
      }

      html += '<div class="scenario-list">';
      if (scenarios.length === 0 && row.status !== 'uncovered' && row.status !== 'drifted' && row.status !== 'manual') {
        html += '<div class="scenario-item" style="color:var(--text-muted);font-style:italic">No matching scenarios found</div>';
      }
      scenarios.forEach(s => {
        html += '<div class="scenario-item">';
        html += '<div class="scenario-name"><span>' + esc(s.scenario.name) + '</span><span>' + badgeFor(getScenarioStatus(s.scenario)) + '</span></div>';
        (s.scenario.steps || []).forEach(step => {
          const kw = (step.keyword || '').trim().toLowerCase().replace(/\*/, 'and');
          const kwClass = ['given','when','then','and','but'].includes(kw) ? kw : 'and';
          const stepStatus = (step.result && step.result.status) || '';
          const dur = step.result ? step.result.duration : null;
          html += '<div class="step">';
          html += '<span class="step-status ' + stepStatus + '"></span>';
          html += '<span class="step-kw ' + kwClass + '">' + esc(step.keyword) + '</span>';
          html += '<span class="step-text">' + esc(step.name) + '</span>';
          html += '<span class="step-dur">' + fmtDur(dur) + '</span>';
          html += '</div>';
        });
        html += '</div>';
      });
      html += '</div>'; /* scenario-list */
      html += '</div>'; /* vm-row */
    });

    html += '</div>'; /* req-body */
    html += '</div>'; /* req-card */
  });

  /* Orphaned tests */
  if (REPORT.orphaned_tests && REPORT.orphaned_tests.length) {
    html += '<h3 style="margin:20px 0 8px;color:var(--orphaned)">Orphaned Tests</h3>';
    html += '<p style="font-size:0.85rem;color:var(--text-muted);margin-bottom:12px">These scenarios reference requirements or verification criteria that no longer exist in the model. They should be removed or reassigned.</p>';
    REPORT.orphaned_tests.forEach(o => {
      const reqIds = (o.orphaned_req_ids || []).join(', ');
      const vmIds = (o.orphaned_vm_ids || []).join(', ');
      const file = o.feature_file || '';
      const name = o.name || file || 'Unknown scenario';
      html += '<div class="req-card" style="border-color:var(--orphaned)">';
      html += '<div class="req-header" style="cursor:default">';
      html += badgeFor('orphaned');
      html += '<span class="req-title" style="margin-left:8px">' + esc(name) + '</span>';
      html += '</div>';
      html += '<div class="req-body open" style="display:block;padding:12px 16px">';
      if (file) html += '<div style="margin-bottom:6px"><strong>Feature file:</strong> <code style="font-size:0.85rem">' + esc(file) + '</code></div>';
      if (reqIds) html += '<div style="margin-bottom:6px"><strong>References deleted requirement(s):</strong> <code style="font-size:0.85rem;color:var(--fail)">' + esc(reqIds) + '</code></div>';
      if (vmIds) html += '<div style="margin-bottom:6px"><strong>References deleted VC(s):</strong> <code style="font-size:0.85rem;color:var(--fail)">' + esc(vmIds) + '</code></div>';
      html += '<div style="font-size:0.85rem;color:var(--text-muted);margin-top:8px"><strong>Action required:</strong> Delete this feature file or update its tags to reference a valid requirement.</div>';
      html += '</div>';
      html += '</div>';
    });
  }

  container.innerHTML = html;
}

function getScenarioStatus(scenario) {
  const steps = scenario.steps || [];
  for (let i = 0; i < steps.length; i++) {
    const st = steps[i].result ? steps[i].result.status : '';
    if (st === 'failed' || st === 'undefined') return 'fail';
  }
  return 'pass';
}

function toggleReq(el) {
  const body = el.nextElementSibling;
  const arrow = el.querySelector('.arrow');
  body.classList.toggle('open');
  arrow.classList.toggle('open');
}

function toggleVM(el) {
  /* Toggle the scenario-list (skip criteria div if present) */
  let sibling = el.nextElementSibling;
  while (sibling && !sibling.classList.contains('scenario-list')) sibling = sibling.nextElementSibling;
  if (sibling) {
    sibling.classList.toggle('open');
    el.querySelector('.arrow').classList.toggle('open');
  }
}

/* Expand All / Collapse All */
function toggleAllReqs() {
  const bodies = document.querySelectorAll('.req-body');
  const btn = document.getElementById('btn-expand-all');
  const anyOpen = Array.from(bodies).some(b => b.classList.contains('open'));
  bodies.forEach(b => { anyOpen ? b.classList.remove('open') : b.classList.add('open'); });
  document.querySelectorAll('.req-header .arrow').forEach(a => { anyOpen ? a.classList.remove('open') : a.classList.add('open'); });
  if (btn) btn.textContent = anyOpen ? 'Expand All' : 'Collapse All';
}

/* Navigate from Gate item to Traceability Matrix */
function navigateToVC(reqId, vmId, isOrphan) {
  /* Switch to Tab 1 */
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelector('[data-tab="traceability"]').classList.add('active');
  document.getElementById('panel-traceability').classList.add('active');

  /* Clear filters so the target card is visible */
  ['f-status', 'f-method', 'f-search'].forEach(id => {
    const el = document.getElementById(id);
    if (el) { el.tagName === 'SELECT' ? el.value = 'all' : (el.value = ''); }
  });
  applyFilters();

  /* Find and expand the requirement card */
  const cards = document.querySelectorAll('.req-card');
  let targetCard = null;
  cards.forEach(card => {
    if (card.getAttribute('data-req') === reqId) targetCard = card;
  });

  if (targetCard) {
    /* Open the req-body if closed */
    const body = targetCard.querySelector('.req-body');
    const arrow = targetCard.querySelector('.req-header .arrow');
    if (body && !body.classList.contains('open')) {
      body.classList.add('open');
      if (arrow) arrow.classList.add('open');
    }

    /* Find the VM row and highlight it */
    let targetVM = null;
    targetCard.querySelectorAll('.vm-row').forEach(vr => {
      const vmHeader = vr.querySelector('.vm-id');
      if (vmHeader && vmHeader.textContent.trim() === vmId) targetVM = vr;
    });

    /* Scroll to target */
    const scrollTarget = targetVM || targetCard;
    scrollTarget.scrollIntoView({ behavior: 'smooth', block: 'center' });

    /* Flash highlight */
    scrollTarget.style.transition = 'background 0.3s';
    scrollTarget.style.background = '#FFF3CD';
    setTimeout(() => { scrollTarget.style.background = ''; }, 2000);
    return;
  }

  /* If no card found (orphaned — req doesn't exist), scroll to orphaned section */
  const orphanSection = document.querySelector('h3');
  if (orphanSection) {
    const headers = document.querySelectorAll('#trace-accordion h3');
    headers.forEach(h => {
      if (h.textContent.includes('Orphaned')) {
        h.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    });
  }
}

/* Filters */
['f-status','f-method','f-search'].forEach(id => {
  const el = document.getElementById(id);
  if (el) el.addEventListener(el.tagName === 'SELECT' ? 'change' : 'input', applyFilters);
});

function applyFilters() {
  const status = document.getElementById('f-status').value;
  const method = document.getElementById('f-method').value;
  const search = document.getElementById('f-search').value.toLowerCase();

  document.querySelectorAll('.req-card').forEach(card => {
    /* Search only matches against req header (ID + title) and VM header (VM ID) */
    const headerText = (card.querySelector('.req-header') || {}).textContent || '';
    const cardMatchesSearch = !search || headerText.toLowerCase().includes(search);

    const vmRows = card.querySelectorAll('.vm-row');

    /* Orphaned cards have no VM rows — only filter by search */
    if (vmRows.length === 0) {
      card.style.display = cardMatchesSearch ? '' : 'none';
      return;
    }

    let anyVisible = false;
    vmRows.forEach(vr => {
      const s = vr.getAttribute('data-status');
      const m = vr.getAttribute('data-method');
      const vmHeaderText = (vr.querySelector('.vm-header') || {}).textContent || '';
      const vmMatchesSearch = !search || vmHeaderText.toLowerCase().includes(search) || cardMatchesSearch;
      let show = true;
      if (status !== 'all' && s !== status) show = false;
      if (method !== 'all' && m !== method) show = false;
      if (!vmMatchesSearch) show = false;
      vr.style.display = show ? '' : 'none';
      if (show) anyVisible = true;
    });
    card.style.display = anyVisible ? '' : 'none';
  });
  /* Show empty state if all cards are hidden */
  let noResults = document.getElementById('filter-empty-state');
  const anyCards = document.querySelector('.req-card[style=""],.req-card:not([style])');
  if (!anyCards && (status !== 'all' || method !== 'all' || search)) {
    if (!noResults) {
      noResults = document.createElement('div');
      noResults.id = 'filter-empty-state';
      noResults.className = 'empty-state';
      noResults.innerHTML = '<h3>No matching results</h3><p>Try adjusting your filters or search term.</p>';
      document.getElementById('trace-accordion').appendChild(noResults);
    }
    noResults.style.display = '';
  } else if (noResults) {
    noResults.style.display = 'none';
  }

  /* Search highlight: mark matching text in visible req-id and req-title spans */
  document.querySelectorAll('#trace-accordion mark.search-hl').forEach(m => {
    const parent = m.parentNode;
    parent.replaceChild(document.createTextNode(m.textContent), m);
    parent.normalize();
  });
  if (search) {
    document.querySelectorAll('.req-card:not([style*="none"]) .req-id, .req-card:not([style*="none"]) .req-title, .vm-row:not([style*="none"]) .vm-id').forEach(el => {
      const text = el.textContent;
      const idx = text.toLowerCase().indexOf(search);
      if (idx >= 0) {
        el.innerHTML = esc(text.substring(0, idx)) + '<mark class="search-hl">' + esc(text.substring(idx, idx + search.length)) + '</mark>' + esc(text.substring(idx + search.length));
      }
    });
  }
}

/* ================================================================
   TAB: CYBER
   ================================================================ */
function renderSecurity() {
  const container = document.getElementById('security-content');

  if (!SBOM && !GRYPE) {
    container.innerHTML = '<div class="empty-state">' +
      '<div class="icon">&#128274;</div>' +
      '<h3>Cyber Scan Data Not Included</h3>' +
      '<p>Software Bill of Materials (SBOM) and vulnerability scan results are generated<br>by the production Jenkins pipeline using Syft and Grype.</p>' +
      '<p style="margin-top:8px;font-size:0.85rem;color:var(--text-muted)">This report was generated without cyber scan data. When available,<br>this tab will show a full component inventory and vulnerability analysis.</p>' +
      '</div>';
    return;
  }

  let html = '';
  const matches = (GRYPE && GRYPE.matches) || [];
  const components = (SBOM && SBOM.components) || [];

  /* ---- #3 Policy compliance banner ---- */
  if (GRYPE) {
    const hasCritical = matches.some(m => (m.vulnerability || {}).severity === 'Critical');
    const hasHigh = matches.some(m => (m.vulnerability || {}).severity === 'High');
    if (hasCritical) {
      html += '<div style="padding:14px 20px;border-radius:8px;background:var(--fail);color:#fff;font-weight:700;font-size:1rem;margin-bottom:20px;display:flex;align-items:center;gap:12px">';
      html += '<span style="font-size:1.4rem">\u2717</span> POLICY: FAIL \u2014 Critical vulnerabilities detected. Deployment blocked per security policy.';
      html += '</div>';
    } else if (hasHigh) {
      html += '<div style="padding:14px 20px;border-radius:8px;background:var(--drifted);color:#333;font-weight:700;font-size:1rem;margin-bottom:20px;display:flex;align-items:center;gap:12px">';
      html += '<span style="font-size:1.4rem">\u26A0</span> POLICY: WARNING \u2014 High severity vulnerabilities found. Review required before deployment.';
      html += '</div>';
    } else if (matches.length === 0) {
      html += '<div style="padding:14px 20px;border-radius:8px;background:var(--pass);color:#fff;font-weight:700;font-size:1rem;margin-bottom:20px;display:flex;align-items:center;gap:12px">';
      html += '<span style="font-size:1.4rem">\u2713</span> POLICY: PASS \u2014 No vulnerabilities detected.';
      html += '</div>';
    } else {
      html += '<div style="padding:14px 20px;border-radius:8px;background:var(--pass);color:#fff;font-weight:700;font-size:1rem;margin-bottom:20px;display:flex;align-items:center;gap:12px">';
      html += '<span style="font-size:1.4rem">\u2713</span> POLICY: PASS \u2014 ' + matches.length + ' vulnerability(s) found, none above threshold.';
      html += '</div>';
    }
  }

  /* ---- Severity breakdown cards ---- */
  if (GRYPE) {
    const sevCounts = { Critical: 0, High: 0, Medium: 0, Low: 0, Negligible: 0 };
    let withFix = 0, noFix = 0;
    matches.forEach(m => {
      const sev = (m.vulnerability && m.vulnerability.severity) || 'Unknown';
      if (sevCounts[sev] !== undefined) sevCounts[sev]++;
      const fix = m.vulnerability && m.vulnerability.fix;
      const fixVersions = fix && fix.versions ? fix.versions : [];
      if (fixVersions.length > 0) withFix++; else noFix++;
    });

    html += '<h2 class="section-title" style="margin-top:0">Vulnerability Summary</h2>';
    html += '<div class="sev-cards">';
    ['Critical','High','Medium','Low','Negligible'].forEach(s => {
      html += '<div class="sev-card sev-' + s.toLowerCase() + '"><div class="sev-val">' + sevCounts[s] + '</div><div class="sev-lbl">' + s + '</div></div>';
    });
    html += '</div>';

    /* ---- #2 Fix availability summary ---- */
    html += '<div style="display:flex;gap:16px;margin:12px 0 20px;font-size:0.9rem">';
    html += '<span style="color:var(--pass);font-weight:600">\u2713 ' + withFix + ' with fix available</span>';
    html += '<span style="color:var(--fail);font-weight:600">\u2717 ' + noFix + ' no fix available</span>';
    html += '<span style="color:var(--text-muted)">' + matches.length + ' total</span>';
    html += '</div>';

    /* ---- #1 Affected components tied to architecture ---- */
    if (REQUIREMENTS && REQUIREMENTS.requirements) {
      const affectedPkgs = new Set(matches.map(m => (m.artifact || {}).name));
      const compToReqs = {};
      REQUIREMENTS.requirements.forEach(req => {
        (req.satisfiedBy || []).forEach(comp => {
          if (!compToReqs[comp]) compToReqs[comp] = [];
          compToReqs[comp].push(req.requirementId);
        });
      });
      /* Check if any satisfiedBy components share names with vulnerable packages */
      const archComponents = Object.keys(compToReqs);
      if (archComponents.length > 0) {
        html += '<div style="background:#f9fafb;border:1px solid #e9ecef;border-radius:8px;padding:14px 18px;margin-bottom:20px">';
        html += '<div style="font-weight:700;font-size:0.85rem;margin-bottom:8px">Architecture Impact</div>';
        html += '<div style="font-size:0.85rem;color:var(--text-muted);margin-bottom:10px">Mapping vulnerable packages to system components from the Cameo model.</div>';
        html += '<table class="data-table" style="font-size:0.85rem"><thead><tr><th>Package</th><th>Severity</th><th>CVE</th><th style="min-width:120px">Fix</th></tr></thead><tbody>';
        matches.forEach(m => {
          const v = m.vulnerability || {};
          const a = m.artifact || {};
          const fixVersions = v.fix && v.fix.versions ? v.fix.versions : [];
          const fixStr = fixVersions.length > 0
            ? '<span style="color:var(--pass);font-weight:600">' + esc(fixVersions.join(', ')) + '</span>'
            : '<span style="color:var(--fail);font-weight:600">No fix</span>';
          html += '<tr>';
          html += '<td><strong>' + esc(a.name) + '</strong> ' + esc(a.version) + '</td>';
          html += '<td><span class="badge" style="background:var(--sev-' + (v.severity||'negligible').toLowerCase() + ');color:#fff">' + esc(v.severity) + '</span></td>';
          html += '<td style="font-family:monospace;font-size:0.8rem">' + esc(v.id) + '</td>';
          html += '<td>' + fixStr + '</td>';
          html += '</tr>';
        });
        html += '</tbody></table>';
        html += '</div>';
      }
    }

    /* ---- #7 Severity filter + #8 CVE links + #4 CVE year + #6 CSV export ---- */
    if (matches.length) {
      html += '<h2 class="section-title">Vulnerability Details</h2>';
      html += '<div class="filter-row">';
      html += '<label>Severity:</label>';
      html += '<select id="vuln-sev-filter" onchange="filterVulns()">';
      html += '<option value="all">All</option>';
      ['Critical','High','Medium','Low','Negligible'].forEach(s => {
        html += '<option value="' + s + '">' + s + '</option>';
      });
      html += '</select>';
      html += '<label style="margin-left:8px">Search:</label>';
      html += '<input type="text" id="vuln-search" placeholder="Filter by CVE, package..." oninput="filterVulns()">';
      html += '<button class="btn btn-secondary" style="padding:4px 14px;font-size:0.8rem;margin-left:auto" onclick="exportVulnCSV()">Download CSV</button>';
      html += '</div>';
      html += '<div class="table-scroll"><table class="data-table" id="vuln-table"><thead><tr>';
      html += '<th>CVE ID</th><th>Year</th><th>Severity</th><th>Package</th><th>Version</th><th>Fix Available</th><th>Description</th>';
      html += '</tr></thead><tbody>';
      matches.forEach(m => {
        const v = m.vulnerability || {};
        const a = m.artifact || {};
        const fixVersions = v.fix && v.fix.versions ? v.fix.versions : [];
        const fixCell = fixVersions.length > 0
          ? '<span style="color:var(--pass);font-weight:600">\u2713 ' + esc(fixVersions.join(', ')) + '</span>'
          : '<span style="color:var(--fail);font-weight:600">\u2717 No fix</span>';
        /* #4 Extract year from CVE ID */
        const cveYear = (v.id || '').match(/CVE-(\d{4})/);
        const yearStr = cveYear ? cveYear[1] : '\u2014';
        /* #8 CVE link */
        const cveLink = '<span style="font-family:monospace" title="' + esc(v.description || '') + '">' + esc(v.id) + '</span>';
        html += '<tr data-severity="' + esc(v.severity || '') + '">';
        html += '<td>' + cveLink + '</td>';
        html += '<td style="text-align:center">' + yearStr + '</td>';
        html += '<td><span class="badge" style="background:var(--sev-' + (v.severity||'negligible').toLowerCase() + ');color:#fff">' + esc(v.severity) + '</span></td>';
        html += '<td>' + esc(a.name) + '</td>';
        html += '<td>' + esc(a.version) + '</td>';
        html += '<td>' + fixCell + '</td>';
        html += '<td style="max-width:300px;font-size:0.8rem">' + esc(v.description || '').substring(0, 200) + '</td>';
        html += '</tr>';
      });
      html += '</tbody></table></div>';
    } else {
      html += '<p style="color:var(--pass);font-weight:600;margin:12px 0">\u2713 No vulnerabilities found.</p>';
    }
  }

  /* ---- #5 SBOM with dependency type + component count ---- */
  if (SBOM) {
    html += '<h2 class="section-title">SBOM Component Inventory (' + components.length + ' components)</h2>';

    /* Group by type */
    const byType = {};
    components.forEach(c => {
      const t = c.type || 'unknown';
      byType[t] = (byType[t] || 0) + 1;
    });
    html += '<div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:12px">';
    Object.entries(byType).forEach(([t, count]) => {
      html += '<span style="font-size:0.82rem;padding:4px 10px;background:#f9fafb;border:1px solid #e9ecef;border-radius:12px">' + esc(t) + ': <strong>' + count + '</strong></span>';
    });
    html += '</div>';

    if (components.length) {
      /* Mark which components have vulnerabilities */
      const vulnPkgs = {};
      matches.forEach(m => {
        const a = m.artifact || {};
        const v = m.vulnerability || {};
        const key = a.name + '@' + a.version;
        if (!vulnPkgs[key]) vulnPkgs[key] = [];
        vulnPkgs[key].push(v.severity || 'Unknown');
      });

      html += '<div class="filter-row"><label>Search:</label><input type="text" id="sbom-search" placeholder="Filter components..." oninput="filterSBOM()"></div>';
      html += '<div class="table-scroll"><table class="data-table" id="sbom-table"><thead><tr>';
      html += '<th>Name</th><th>Version</th><th>Type</th><th>Vulnerabilities</th><th>PURL</th>';
      html += '</tr></thead><tbody>';
      components.forEach(c => {
        const key = c.name + '@' + c.version;
        const vulns = vulnPkgs[key] || [];
        let vulnCell = '<span style="color:var(--pass)">\u2713 None</span>';
        if (vulns.length > 0) {
          const worst = ['Critical','High','Medium','Low','Negligible'].find(s => vulns.includes(s)) || 'Unknown';
          vulnCell = '<span class="badge" style="background:var(--sev-' + worst.toLowerCase() + ');color:#fff">' + vulns.length + ' (' + worst + ')</span>';
        }
        html += '<tr><td><strong>' + esc(c.name) + '</strong></td><td>' + esc(c.version) + '</td><td>' + esc(c.type) + '</td><td>' + vulnCell + '</td><td style="font-size:0.75rem;word-break:break-all;color:var(--text-muted)">' + esc(c.purl || '') + '</td></tr>';
      });
      html += '</tbody></table></div>';
    }
  }

  container.innerHTML = html;
}

/* #7 Vulnerability filter */
function filterVulns() {
  const sev = (document.getElementById('vuln-sev-filter') || {}).value || 'all';
  const search = ((document.getElementById('vuln-search') || {}).value || '').toLowerCase();
  document.querySelectorAll('#vuln-table tbody tr').forEach(r => {
    const rowSev = r.getAttribute('data-severity') || '';
    const text = r.textContent.toLowerCase();
    let show = true;
    if (sev !== 'all' && rowSev !== sev) show = false;
    if (search && !text.includes(search)) show = false;
    r.style.display = show ? '' : 'none';
  });
}

/* #6 CSV export */
function exportVulnCSV() {
  if (!GRYPE || !GRYPE.matches) return;
  const rows = [['CVE ID','Severity','Package','Version','Fix Versions','Description']];
  GRYPE.matches.forEach(m => {
    const v = m.vulnerability || {};
    const a = m.artifact || {};
    const fix = v.fix && v.fix.versions ? v.fix.versions.join('; ') : '';
    rows.push([v.id || '', v.severity || '', a.name || '', a.version || '', fix, (v.description || '').replace(/"/g, '""')]);
  });
  const csv = rows.map(r => r.map(c => '"' + c + '"').join(',')).join('\n');
  const blob = new Blob([csv], { type: 'text/csv' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'vulnerabilities.csv';
  a.click();
  URL.revokeObjectURL(a.href);
}

function filterSBOM() {
  const q = (document.getElementById('sbom-search') || {}).value || '';
  const rows = document.querySelectorAll('#sbom-table tbody tr');
  const search = q.toLowerCase();
  rows.forEach(r => { r.style.display = r.textContent.toLowerCase().includes(search) ? '' : 'none'; });
}

/* ================================================================
   TAB 3: QUALITY GATES
   ================================================================ */
function renderGates() {
  const container = document.getElementById('gates-content');
  if (!TRACEABILITY) { container.innerHTML = '<div class="empty-state"><h3>No traceability data available</h3></div>'; return; }

  const gates = [
    { key: 'gate_a', name: 'Gate A — Coverage', desc: 'Ensures every verification criteria has at least one Gherkin scenario. Generates stubs for any gaps.' },
    { key: 'gate_b', name: 'Gate B — Drift Detection', desc: 'Detects when requirement verification criteria change between model versions. Flags scenarios for review.' },
    { key: 'gate_c', name: 'Gate C — Orphan Detection', desc: 'Finds test scenarios referencing requirements or VCs that no longer exist in the model.' },
  ];

  let html = '<div class="gate-cards">';
  gates.forEach(g => {
    const data = TRACEABILITY[g.key] || {};
    const passed = data.passed !== false;
    const items = data.items || [];
    const gateLabel = g.key === 'gate_a' ? 'A' : g.key === 'gate_b' ? 'B' : 'C';
    html += '<div class="gate-card ' + (passed ? 'gate-pass' : 'gate-fail') + '" data-gate="' + gateLabel + '">';
    html += '<div class="gate-title"><span class="gate-name">' + g.name + '</span>' + badgeFor(passed ? 'pass' : 'fail') + '</div>';
    html += '<div class="gate-desc">' + g.desc + '</div>';
    if (data.message) html += '<p style="font-size:0.85rem;margin-bottom:8px">' + esc(data.message) + '</p>';
    if (items.length === 0) {
      html += '<p style="color:var(--pass);font-size:0.85rem">No issues detected.</p>';
    }
    items.forEach(item => {
      const id = item.verificationMethodId || item.vm_id || item.requirementId || '';
      const reqId = item.requirementId || (id.match(/^(.*)-VM-\d+$/) || [])[1] || '';
      const isOrphan = g.key === 'gate_c';
      html += '<div class="gate-item" style="cursor:pointer" onclick="navigateToVC(\'' + esc(reqId) + '\',\'' + esc(id) + '\',' + isOrphan + ')" title="Click to view in Traceability Matrix">';
      html += '<span class="gi-id" style="color:var(--blue-ng)">' + esc(id) + '</span> <span style="font-size:0.75rem;color:var(--text-muted)">&#x2197;</span>';
      if (item.method) html += ' <span style="font-size:0.8rem;color:var(--text-muted)">(' + esc(item.method) + ')</span>';
      if (item.title) html += '<div class="gi-detail">' + esc(item.title) + '</div>';
      if (item.stubGenerated) html += '<div class="gi-detail">Stub: ' + esc(item.stubGenerated) + '</div>';
      if (item.oldHash && item.newHash) html += '<div class="gi-detail">Hash changed: ' + esc(item.oldHash.substring(0,12)) + '... &rarr; ' + esc(item.newHash.substring(0,12)) + '...</div>';
      if (item.orphanedReqIds && item.orphanedReqIds.length) html += '<div class="gi-detail">Orphaned IDs: ' + item.orphanedReqIds.map(esc).join(', ') + '</div>';
      if (item.orphanedVmIds && item.orphanedVmIds.length) html += '<div class="gi-detail">Orphaned VC IDs: ' + item.orphanedVmIds.map(esc).join(', ') + '</div>';
      if (item.featureFile) html += '<div class="gi-detail">Feature: ' + esc(item.featureFile) + '</div>';
      html += '</div>';
    });
    html += '</div>';
  });
  html += '</div>';

  /* Overall */
  html += '<div style="margin-top:20px;text-align:center">';
  html += '<strong>Overall Pipeline: </strong>' + badgeFor(TRACEABILITY.overall_pass ? 'pass' : 'fail');
  html += '<span style="margin-left:8px;font-size:0.85rem;color:var(--text-muted)">';
  html += TRACEABILITY.requirements_total + ' requirements, ' + TRACEABILITY.vms_total + ' VCs, ' + TRACEABILITY.features_scanned + ' features scanned';
  html += '</span></div>';

  container.innerHTML = html;
}

/* ================================================================
   TAB 4: TEST EXECUTION
   ================================================================ */
function renderTests() {
  const container = document.getElementById('tests-content');

  /* Filter out @manual / @STUB features — they aren't automated tests */
  function isManualFeature(feat) {
    const tags = (feat.tags || []).map(t => (typeof t === 'string' ? t : (t.name || '')).replace(/^@/, '').toLowerCase());
    return tags.includes('manual') || tags.includes('stub') || tags.includes('auto_generated');
  }
  const automatedFeatures = behaveFeatures.filter(f => !isManualFeature(f));

  if (!automatedFeatures.length) {
    container.innerHTML = '<div class="empty-state"><h3>No Behave test results available</h3></div>';
    return;
  }

  let totalScenarios = 0, totalSteps = 0, totalDur = 0, scenarioPassed = 0;
  automatedFeatures.forEach(f => {
    (f.elements || []).forEach(el => {
      if (el.keyword === 'Background') return;
      totalScenarios++;
      let passed = true;
      (el.steps || []).forEach(s => {
        totalSteps++;
        if (s.result) totalDur += (s.result.duration || 0);
        if (s.result && (s.result.status === 'failed' || s.result.status === 'undefined')) passed = false;
      });
      if (passed) scenarioPassed++;
    });
  });

  let html = '<div style="display:flex;gap:20px;flex-wrap:wrap;margin-bottom:16px">';
  html += '<div class="info-item"><div class="info-label">Features</div><div class="info-value">' + automatedFeatures.length + '</div></div>';
  html += '<div class="info-item"><div class="info-label">Scenarios</div><div class="info-value">' + totalScenarios + '</div></div>';
  html += '<div class="info-item"><div class="info-label">Steps</div><div class="info-value">' + totalSteps + '</div></div>';
  html += '<div class="info-item"><div class="info-label">Total Duration</div><div class="info-value">' + fmtDur(totalDur) + '</div></div>';
  html += '<div class="info-item"><div class="info-label">Pass Rate</div><div class="info-value" style="color:' + (scenarioPassed === totalScenarios ? 'var(--pass)' : 'var(--fail)') + '">' + (totalScenarios ? Math.round(scenarioPassed/totalScenarios*100) : 0) + '%</div></div>';
  html += '</div>';
  html += '<div class="filter-row" style="margin-bottom:16px">';
  html += '<label for="test-filter">Show:</label>';
  html += '<select id="test-filter" onchange="filterTests()">';
  html += '<option value="all">All Features</option>';
  html += '<option value="failed">Failures Only</option>';
  html += '<option value="passed">Passed Only</option>';
  html += '</select>';
  html += '<label style="margin-left:8px">Search:</label>';
  html += '<input type="text" id="test-search" placeholder="Filter by feature or scenario name..." oninput="filterTests()">';
  html += '</div>';

  automatedFeatures.forEach((feat, fi) => {
    const featureStatus = feat.status || 'passed';
    const scenarios = (feat.elements || []).filter(e => e.keyword !== 'Background');
    let featDur = 0;
    scenarios.forEach(sc => (sc.steps || []).forEach(s => { if (s.result) featDur += (s.result.duration || 0); }));

    html += '<div class="test-feature" data-status="' + featureStatus + '">';
    html += '<div class="test-feature-header" onclick="toggleTestFeature(this)">';
    html += '<span class="arrow">&#9654;</span>';
    html += '<span>' + esc(feat.name) + '</span>';
    html += '<span class="feat-dur">' + fmtDur(featDur) + '</span>';
    html += '<span class="feat-status">' + badgeFor(featureStatus === 'passed' ? 'pass' : 'fail') + '</span>';
    html += '</div>';
    html += '<div class="test-feature-body">';

    scenarios.forEach(sc => {
      const scStatus = getScenarioStatus(sc);
      let scDur = 0;
      (sc.steps || []).forEach(s => { if (s.result) scDur += (s.result.duration || 0); });

      html += '<div class="test-scenario">';
      html += '<div class="test-scenario-name"><span>' + esc(sc.name) + '</span><span>' + fmtDur(scDur) + ' ' + badgeFor(scStatus) + '</span></div>';
      (sc.steps || []).forEach(step => {
        const kw = (step.keyword || '').trim().toLowerCase().replace(/\*/, 'and');
        const kwClass = ['given','when','then','and','but'].includes(kw) ? kw : 'and';
        const stepStatus = (step.result && step.result.status) || '';
        const dur = step.result ? step.result.duration : null;
        html += '<div class="step">';
        html += '<span class="step-status ' + stepStatus + '"></span>';
        html += '<span class="step-kw ' + kwClass + '">' + esc(step.keyword) + '</span>';
        html += '<span class="step-text">' + esc(step.name) + '</span>';
        html += '<span class="step-dur">' + fmtDur(dur) + '</span>';
        html += '</div>';
        if (stepStatus === 'failed' && step.result.error_message) {
          html += '<div style="padding:4px 0 4px 80px;color:var(--fail);font-size:0.8rem;font-family:monospace;white-space:pre-wrap">' + esc(step.result.error_message) + '</div>';
        }
      });
      html += '</div>';
    });

    html += '</div></div>';
  });

  container.innerHTML = html;
}

function filterTests() {
  const filter = (document.getElementById('test-filter') || {}).value || 'all';
  const search = ((document.getElementById('test-search') || {}).value || '').toLowerCase();
  document.querySelectorAll('.test-feature').forEach(feat => {
    const status = feat.getAttribute('data-status') || '';
    const text = feat.textContent.toLowerCase();
    let show = true;
    if (filter === 'failed' && status !== 'failed') show = false;
    if (filter === 'passed' && status !== 'passed') show = false;
    if (search && !text.includes(search)) show = false;
    feat.style.display = show ? '' : 'none';
  });
}

function toggleTestFeature(el) {
  const body = el.nextElementSibling;
  body.classList.toggle('open');
  el.querySelector('.arrow').classList.toggle('open');
}

/* ================================================================
   TAB 5: EXPORT & METADATA
   ================================================================ */
function renderMetadata() {
  const grid = document.getElementById('metadata-grid');
  const meta = (REQUIREMENTS && REQUIREMENTS.exportMetadata) || {};
  const items = [
    ['Model Version', meta.modelVersion || '—'],
    ['Cameo Version', meta.cameoVersion || '—'],
    ['Project Name', meta.projectName || '—'],
    ['Export Timestamp', meta.exportTimestamp || '—'],
    ['Total Requirements', (REPORT.summary && REPORT.summary.total_requirements) || '—'],
    ['Total VCs', (REPORT.summary && REPORT.summary.total_vms) || '—'],
    ['Report Generated', REPORT.generated_at || '—'],
    ['Features Scanned', (TRACEABILITY && TRACEABILITY.features_scanned) || '—'],
  ];
  grid.innerHTML = items.map(([l,v]) => '<div class="info-item"><div class="info-label">' + l + '</div><div class="info-value">' + esc(String(v)) + '</div></div>').join('');
}

function downloadJSON() {
  const blob = new Blob([JSON.stringify(REPORT, null, 2)], { type: 'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'traceability_report.json';
  a.click();
  URL.revokeObjectURL(a.href);
}

/* ================================================================
   INIT
   ================================================================ */
renderTraceability();
renderSecurity();
renderGates();
renderTests();
renderMetadata();

/* Item 1: Summary sentence — keep it short */
(function() {
  const el = document.getElementById('hero-summary-sentence');
  if (!el || !REPORT || !REPORT.summary) return;
  const s = REPORT.summary;
  const gatesFailed = [
    TRACEABILITY && TRACEABILITY.gate_a && !TRACEABILITY.gate_a.passed,
    TRACEABILITY && TRACEABILITY.gate_b && !TRACEABILITY.gate_b.passed,
    TRACEABILITY && TRACEABILITY.gate_c && !TRACEABILITY.gate_c.passed,
  ].filter(Boolean).length;

  if (s.failed === 0 && s.uncovered_vms === 0 && s.drifted_vms === 0 && gatesFailed === 0) {
    el.innerHTML = '<strong>' + s.passed + ' of ' + s.total_vms + '</strong> verification criteria passed. All quality gates passed.';
    el.style.borderLeftColor = 'var(--pass)';
  } else {
    const issues = [];
    if (s.failed > 0) issues.push(s.failed + ' failed');
    if (s.uncovered_vms > 0) issues.push(s.uncovered_vms + ' uncovered');
    if (s.drifted_vms > 0) issues.push(s.drifted_vms + ' drifted');
    el.innerHTML = '<strong>' + s.passed + ' of ' + s.total_vms + '</strong> verification criteria passed. ' +
      '<strong>' + issues.join(', ') + '</strong> — see Quality Gates for details.';
    el.style.borderLeftColor = s.failed > 0 ? 'var(--fail)' : 'var(--uncovered)';
  }
})();

/* Item 6: Human-readable timestamp */
(function() {
  const el = document.getElementById('hero-timestamp');
  if (el && REPORT && REPORT.generated_at) el.textContent = 'Generated: ' + fmtDate(REPORT.generated_at);
})();
</script>
</body>
</html>
