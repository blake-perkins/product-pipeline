/* ================================================================
   TAB: EXECUTIVE SUMMARY
   ================================================================ */
function renderExecutiveSummary() {
  const container = document.getElementById('summary-content');
  if (!REPORT || !REPORT.summary) { container.innerHTML = '<div class="empty-state"><h3>No data available</h3></div>'; return; }
  const s = REPORT.summary;
  const rows = REPORT.requirements || [];

  /* Calculate readiness percentage */
  const inScope = s.in_scope_vcs || s.total_vcs;
  const resolved = s.passed; /* only passed tests count as complete */
  const readinessPct = inScope > 0 ? Math.round(resolved / inScope * 100) : 0;

  /* Determine ring color */
  const hasFailures = s.failed > 0;
  const hasCriticalCVE = GRYPE && GRYPE.matches && GRYPE.matches.some(m => (m.vulnerability || {}).severity === 'Critical');
  const ringColor = (hasFailures || hasCriticalCVE) ? 'var(--fail)' : readinessPct >= 100 ? 'var(--pass)' : readinessPct >= 50 ? 'var(--blue-ng)' : 'var(--uncovered)';

  /* Build remaining items list */
  const remaining = [];
  if (s.failed > 0) remaining.push('<span style="color:var(--fail)">&#10007; ' + s.failed + ' test failure' + (s.failed > 1 ? 's' : '') + ' to resolve</span>');
  if (s.drifted_vcs > 0) remaining.push('<span style="color:var(--drifted)">&#8635; ' + s.drifted_vcs + ' criteria change' + (s.drifted_vcs > 1 ? 's' : '') + ' to review</span>');
  if (s.uncovered_vcs > 0) remaining.push('<span style="color:var(--uncovered)">&#8212; ' + s.uncovered_vcs + ' scenario' + (s.uncovered_vcs > 1 ? 's' : '') + ' to write</span>');
  if (s.orphaned_tests > 0) remaining.push('<span style="color:var(--orphaned)">? ' + s.orphaned_tests + ' orphaned test' + (s.orphaned_tests > 1 ? 's' : '') + ' to clean up</span>');
  if (hasCriticalCVE) remaining.push('<span style="color:var(--fail)">&#9888; Critical vulnerability to address</span>');

  /* Readiness label */
  const readinessLabel = readinessPct >= 100 && remaining.length === 0
    ? 'Release Ready'
    : remaining.length > 0
      ? remaining.length + ' item' + (remaining.length > 1 ? 's' : '') + ' remaining before release'
      : 'Release Ready';

  let html = '';

  /* Section 1: Readiness Ring */
  const circumference = 2 * Math.PI * 46;
  const dashOffset = circumference * (1 - readinessPct / 100);
  html += '<div class="readiness">';
  html += '<div class="readiness-ring">';
  html += '<svg width="120" height="120" viewBox="0 0 120 120">';
  html += '<circle cx="60" cy="60" r="46" fill="none" stroke="#e9ecef" stroke-width="10"/>';
  html += '<circle cx="60" cy="60" r="46" fill="none" stroke="' + ringColor + '" stroke-width="10" stroke-linecap="round" stroke-dasharray="' + circumference.toFixed(1) + '" stroke-dashoffset="' + dashOffset.toFixed(1) + '"/>';
  html += '</svg>';
  html += '<span class="pct" style="color:' + ringColor + '">' + readinessPct + '%</span>';
  html += '</div>';
  html += '<div class="readiness-info">';
  html += '<h2>Release Readiness</h2>';
  html += '<p>' + readinessLabel + '</p>';
  if (remaining.length > 0) {
    html += '<div class="readiness-items">' + remaining.join('<br>') + '</div>';
  }
  html += '</div>';
  html += '</div>';

  html += '<div class="exec-grid">';

  /* Section 2: Release Progress (left column) — click to navigate */
  html += '<div class="exec-section" style="cursor:pointer" onclick="switchTab(\'releases\')" onmouseenter="this.style.borderColor=\'var(--blue-ng)\'" onmouseleave="this.style.borderColor=\'#e9ecef\'">';
  html += '<div style="display:flex;justify-content:space-between;align-items:center"><h3>Release Progress</h3><span style="font-size:0.75rem;color:var(--blue-ng)">View Details &#8250;</span></div>';
  if (RELEASE_PLAN && RELEASE_PLAN.releases && RELEASE_PLAN.releases.length) {
    const reqToVCs = {};
    if (REQUIREMENTS && REQUIREMENTS.requirements) {
      REQUIREMENTS.requirements.forEach(req => {
        reqToVCs[req.requirementId] = (req.verificationCriteria || req.verificationMethods || []).map(vc => vc.verificationCriteriaId || vc.verificationMethodId);
      });
    }
    const vcStatus = {};
    rows.forEach(r => { if (r.vc_id) vcStatus[r.vc_id] = r.status; });

    RELEASE_PLAN.releases.forEach(rel => {
      const scopeVCs = [];
      (rel.scope || []).forEach(id => {
        if (id.match(/-VC-\d+$/)) scopeVCs.push(id);
        else if (reqToVCs[id]) reqToVCs[id].forEach(v => scopeVCs.push(v));
      });
      const total = scopeVCs.length;
      const complete = scopeVCs.filter(id => { const st = vcStatus[id]; return st === 'pass'; }).length;
      const manualCount = scopeVCs.filter(id => { const st = vcStatus[id]; return st === 'manual'; }).length;
      const pct = total ? Math.round(complete / total * 100) : 0;
      const released = isReleasedVersion(rel.version);
      const isCurrent = isCurrentVersion(rel.version);
      html += '<div style="margin-bottom:12px' + (released ? ';opacity:0.6' : '') + '">';
      html += '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px">';
      html += '<span style="font-weight:600;font-size:0.9rem">Release ' + esc(rel.version);
      if (released) html += ' <span class="badge" style="background:var(--pass);color:#fff;font-size:0.65rem;vertical-align:middle">RELEASED</span>';
      else if (isCurrent) html += ' <span class="badge" style="background:var(--blue-ng);color:#fff;font-size:0.65rem;vertical-align:middle">CURRENT</span>';
      html += '</span>';
      if (released) {
        html += '<span style="font-size:0.85rem;color:var(--pass);font-weight:600">Shipped</span>';
      } else {
        html += '<span style="font-size:0.85rem;color:' + (pct === 100 && manualCount === 0 ? 'var(--pass)' : 'var(--text-muted)') + ';font-weight:600">' + pct + '% (' + complete + '/' + total + ')' + (manualCount > 0 ? ' <span style="color:var(--manual);font-weight:400">+ ' + manualCount + ' manual</span>' : '') + '</span>';
      }
      html += '</div>';
      if (!released) {
        html += '<div style="display:flex;height:8px;border-radius:4px;overflow:hidden;background:#e9ecef">';
        if (complete > 0) html += '<div style="width:' + (complete/total*100) + '%;background:var(--pass)"></div>';
        if (manualCount > 0) html += '<div style="width:' + (manualCount/total*100) + '%;background:var(--manual)" title="Manual: ' + manualCount + '"></div>';
        html += '</div>';
      }
      if (rel.targetDate && !released) html += '<div style="font-size:0.8rem;color:var(--text-muted);margin-top:2px">Target: ' + fmtDate(rel.targetDate + 'T00:00:00Z') + '</div>';
      html += '</div>';
    });
  } else {
    html += '<div style="color:var(--text-muted);font-size:0.85rem;font-style:italic">No release plan defined.</div>';
  }
  html += '</div>';

  /* Section 3: Top Issues (right column) */
  html += '<div class="exec-section">';
  html += '<h3>Top Issues</h3>';
  const issues = [];
  rows.filter(r => r.status === 'fail').forEach(r => {
    issues.push({sev: 0, icon: '&#10007;', color: 'var(--fail)', text: '<strong>' + esc(r.vc_id) + '</strong> — test failed: ' + esc(r.title), vcId: r.vc_id, reqId: r.requirement_id});
  });
  rows.filter(r => r.status === 'drifted').forEach(r => {
    issues.push({sev: 1, icon: '&#8635;', color: 'var(--drifted)', text: '<strong>' + esc(r.vc_id) + '</strong> — criteria drifted: ' + esc(r.title), vcId: r.vc_id, reqId: r.requirement_id});
  });
  rows.filter(r => r.status === 'uncovered').forEach(r => {
    issues.push({sev: 2, icon: '&#8212;', color: 'var(--uncovered)', text: '<strong>' + esc(r.vc_id) + '</strong> — uncovered (' + esc(r.method) + '): ' + esc(r.title), vcId: r.vc_id, reqId: r.requirement_id});
  });
  if (REPORT.orphaned_tests) REPORT.orphaned_tests.forEach(o => {
    issues.push({sev: 3, icon: '?', color: 'var(--orphaned)', text: 'Orphaned: ' + esc(o.name || o.feature_file), vcId: '', reqId: ''});
  });
  issues.sort((a, b) => a.sev - b.sev);
  if (issues.length === 0) {
    html += '<div style="color:var(--pass);font-size:0.95rem;font-weight:600">&#10003; No issues found</div>';
  }
  issues.slice(0, 8).forEach(iss => {
    const clickAttr = iss.reqId ? ' style="cursor:pointer" onclick="navigateToVC(\'' + esc(iss.reqId) + '\',\'' + esc(iss.vcId) + '\',false,\'\')"' : '';
    html += '<div class="exec-issue"' + clickAttr + '>';
    html += '<span style="color:' + iss.color + ';font-size:1rem;min-width:16px">' + iss.icon + '</span>';
    html += '<span>' + iss.text + '</span>';
    html += '</div>';
  });
  html += '</div>';

  html += '</div>'; /* close exec-grid */

  /* Section 4: Cyber Risk Summary — click to navigate */
  html += '<div class="exec-section" style="margin-bottom:20px;cursor:pointer" onclick="switchTab(\'security\')" onmouseenter="this.style.borderColor=\'var(--blue-ng)\'" onmouseleave="this.style.borderColor=\'#e9ecef\'">';
  html += '<div style="display:flex;justify-content:space-between;align-items:center"><h3>Cyber Risk</h3><span style="font-size:0.75rem;color:var(--blue-ng)">View Details &#8250;</span></div>';
  if (!GRYPE || !GRYPE.matches) {
    html += '<div style="color:var(--text-muted);font-size:0.85rem;font-style:italic">Cyber scan data not included in this build.</div>';
  } else if (GRYPE.matches.length === 0) {
    html += '<div style="color:var(--pass);font-size:0.95rem;font-weight:600">&#10003; No vulnerabilities detected</div>';
  } else {
    const sevCounts = {Critical:0, High:0, Medium:0, Low:0, Negligible:0};
    GRYPE.matches.forEach(m => { const sv = (m.vulnerability||{}).severity||'Unknown'; if (sevCounts[sv] !== undefined) sevCounts[sv]++; });
    const policyStatus = sevCounts.Critical > 0 ? 'FAIL' : sevCounts.High > 0 ? 'WARNING' : 'PASS';
    const policyColor = policyStatus === 'FAIL' ? 'var(--fail)' : policyStatus === 'WARNING' ? 'var(--drifted)' : 'var(--pass)';
    html += '<div style="display:flex;align-items:center;gap:12px;margin-bottom:8px">';
    html += '<span style="font-weight:700;color:' + policyColor + '">Policy: ' + policyStatus + '</span>';
    html += '<span style="font-size:0.85rem;color:var(--text-muted)">' + GRYPE.matches.length + ' total vulnerabilities</span>';
    html += '</div>';
    html += '<div style="display:flex;gap:16px;font-size:0.85rem">';
    ['Critical','High','Medium','Low','Negligible'].forEach(sv => {
      if (sevCounts[sv] > 0) {
        html += '<span style="color:var(--sev-' + sv.toLowerCase() + ');font-weight:600">' + sevCounts[sv] + ' ' + sv + '</span>';
      }
    });
    html += '</div>';
  }
  html += '</div>';

  container.innerHTML = html;
}

/* ================================================================
   TAB: RELEASE PROGRESS
   ================================================================ */
function renderReleases() {
  const container = document.getElementById('releases-content');
  if (!RELEASE_PLAN || !RELEASE_PLAN.releases || !RELEASE_PLAN.releases.length) {
    container.innerHTML = '<div class="empty-state"><div class="icon">&#128197;</div><h3>No Release Plan</h3><p>Create a <code>release-plan.json</code> to track requirement delivery across releases.</p></div>';
    return;
  }

  const releases = RELEASE_PLAN.releases;
  const rows = REPORT && REPORT.requirements ? REPORT.requirements : [];

  /* Build a lookup: vcId -> status from report */
  const vcStatus = {};
  rows.forEach(r => { if (r.vc_id) vcStatus[r.vc_id] = r; });

  /* Build a lookup: reqId -> all VC IDs */
  const reqToVCs = {};
  if (REQUIREMENTS && REQUIREMENTS.requirements) {
    REQUIREMENTS.requirements.forEach(req => {
      reqToVCs[req.requirementId] = (req.verificationCriteria || req.verificationMethods || []).map(vc => vc.verificationCriteriaId || vc.verificationMethodId);
    });
  }

  /* Expand scope IDs to VC IDs */
  function expandScope(scopeIds) {
    const vms = [];
    (scopeIds || []).forEach(id => {
      if (id.match(/-VC-\d+$/)) {
        vms.push(id);
      } else if (reqToVCs[id]) {
        reqToVCs[id].forEach(vcId => vms.push(vcId));
      }
    });
    return vms;
  }

  /* Compute cumulative scope up to each release */
  const cumulativeScopes = [];
  let cumulative = new Set();
  releases.forEach(rel => {
    expandScope(rel.scope).forEach(id => cumulative.add(id));
    cumulativeScopes.push(new Set(cumulative));
  });

  /* Overall program progress */
  const allPlannedVCs = cumulativeScopes.length > 0 ? cumulativeScopes[cumulativeScopes.length - 1] : new Set();
  const allComplete = Array.from(allPlannedVCs).filter(id => {
    const st = vcStatus[id];
    return st && st.status === 'pass';
  });

  let html = '<div style="display:flex;gap:20px;flex-wrap:wrap;margin-bottom:24px">';
  html += '<div class="info-item"><div class="info-label">Total Releases</div><div class="info-value">' + releases.length + '</div></div>';
  html += '<div class="info-item"><div class="info-label">Total Planned VCs</div><div class="info-value">' + allPlannedVCs.size + '</div></div>';
  html += '<div class="info-item"><div class="info-label">Program Completion</div><div class="info-value" style="color:' + (allComplete.length === allPlannedVCs.size ? 'var(--pass)' : 'var(--text)') + '">' + (allPlannedVCs.size ? Math.round(allComplete.length / allPlannedVCs.size * 100) : 0) + '%</div></div>';
  html += '</div>';

  releases.forEach((rel, ri) => {
    const scopeVCs = expandScope(rel.scope);
    const counts = { pass: 0, fail: 0, uncovered: 0, drifted: 0, manual: 0, deferred: 0 };
    const vcDetails = [];

    scopeVCs.forEach(vcId => {
      const row = vcStatus[vcId];
      const st = row ? row.status : 'uncovered';
      counts[st] = (counts[st] || 0) + 1;
      vcDetails.push({ vcId, status: st, title: row ? row.title : '', method: row ? row.method : '' });
    });

    const total = scopeVCs.length;
    const complete = counts.pass;
    const pct = total ? Math.round(complete / total * 100) : 0;

    /* Is this the current release? */
    const currentVersion = (REPORT && REPORT.summary && REPORT.summary.in_scope_vcs !== REPORT.summary.total_vcs) ? '' : '';

    /* Target date formatting */
    const targetDate = rel.targetDate ? fmtDate(rel.targetDate + 'T00:00:00Z') : '';

    const relReleased = isReleasedVersion(rel.version);
    const relCurrent = isCurrentVersion(rel.version);
    const borderColor = relReleased ? 'var(--pass)' : pct === 100 ? 'var(--pass)' : pct > 0 ? 'var(--blue-ng)' : 'var(--border)';
    html += '<div style="border:1px solid #e9ecef;border-radius:10px;margin-bottom:16px;overflow:hidden;border-left:4px solid ' + borderColor + '">';

    /* Release header */
    html += '<div style="padding:16px 20px;display:flex;align-items:center;gap:16px;cursor:pointer' + (relReleased ? ';opacity:0.7' : '') + '" onclick="this.nextElementSibling.classList.toggle(\'open\');this.querySelector(\'.arrow\').classList.toggle(\'open\')">';
    html += '<span class="arrow" style="font-size:0.9rem;color:var(--text-muted);transition:transform 0.2s">&#9654;</span>';
    html += '<div style="flex:1">';
    html += '<div style="font-weight:700;font-size:1.1rem;color:var(--navy-1)">Release ' + esc(rel.version);
    if (relReleased) html += ' <span class="badge" style="background:var(--pass);color:#fff;font-size:0.65rem;vertical-align:middle">RELEASED</span>';
    else if (relCurrent) html += ' <span class="badge" style="background:var(--blue-ng);color:#fff;font-size:0.65rem;vertical-align:middle">CURRENT</span>';
    html += '</div>';
    html += '<div style="font-size:0.85rem;color:var(--text-muted)">' + esc(rel.description || '') + '</div>';
    if (targetDate && !relReleased) html += '<div style="font-size:0.8rem;color:var(--text-muted)">Target: ' + targetDate + '</div>';
    html += '</div>';
    html += '<div style="text-align:right;min-width:120px">';
    if (relReleased) {
      html += '<div style="font-size:1.1rem;font-weight:700;color:var(--pass)">&#10003; Shipped</div>';
    } else {
      html += '<div style="font-size:1.4rem;font-weight:700;color:' + (pct === 100 ? 'var(--pass)' : 'var(--text)') + '">' + pct + '%</div>';
      html += '<div style="font-size:0.75rem;color:var(--text-muted)">' + complete + ' of ' + total + ' VCs</div>';
    }
    html += '</div>';
    html += '</div>';

    /* Release body (expandable) */
    html += '<div class="req-body" style="border-top:1px solid #e9ecef">';

    /* Progress bar */
    html += '<div style="padding:12px 20px">';
    html += '<div class="cov-bar" style="display:flex;height:10px;border-radius:5px;overflow:hidden;border:1px solid #e9ecef;background:#f4f7fa">';
    ['pass','fail','drifted','uncovered','manual','deferred'].forEach(s => {
      if (counts[s]) html += '<div style="width:' + (counts[s]/total*100) + '%;background:var(--' + s + ')" title="' + s + ': ' + counts[s] + '"></div>';
    });
    html += '</div>';
    html += '<div style="display:flex;gap:12px;margin-top:6px;font-size:0.8rem;color:var(--text-muted)">';
    ['pass','fail','uncovered','drifted','manual','deferred'].forEach(s => {
      if (counts[s]) html += '<span>' + badgeFor(s) + ' ' + counts[s] + '</span>';
    });
    html += '</div></div>';

    /* VC list */
    html += '<div style="padding:0 20px 12px">';
    vcDetails.forEach(vc => {
      html += '<div style="display:flex;align-items:center;gap:10px;padding:4px 0;font-size:0.85rem;border-bottom:1px solid #f4f7fa">';
      html += '<span style="font-family:monospace;font-weight:600;min-width:180px">' + esc(vc.vcId) + '</span>';
      html += '<span style="min-width:100px;color:var(--text-muted)">' + esc(vc.method) + '</span>';
      html += badgeFor(vc.status);
      html += '<span style="flex:1;color:var(--text-muted);font-size:0.8rem">' + esc(vc.title) + '</span>';
      html += '</div>';
    });
    html += '</div>';

    html += '</div></div>';
  });

  container.innerHTML = html;
}

/* ================================================================
   INIT
   ================================================================ */
renderTraceability();
renderSecurity();
renderGates();
renderTests();
renderMetadata();
renderReleases();
renderExecutiveSummary();

/* Hero: populate release info, blockers, failed list, bar legend */
(function() {
  if (!REPORT || !REPORT.summary) return;
  const s = REPORT.summary;

  /* Release name and details */
  const relName = document.getElementById('hero-release-name');
  const relDetail = document.getElementById('hero-release-detail');
  if (relName && RELEASE_PLAN && RELEASE_PLAN.releases && RELEASE_PLAN.releases.length) {
    /* Find the current release (last one whose scope contributes to in_scope_vcs) */
    /* For now, show the first release that has in-scope VCs not yet fully covered, or the last one */
    const releases = RELEASE_PLAN.releases;
    const currentRel = releases.find(r => isCurrentVersion(r.version)) || releases.find(r => !isReleasedVersion(r.version)) || releases[0];
    relName.textContent = 'Release ' + (currentRel.version || '');
    const parts = [];
    if (currentRel.description) parts.push(currentRel.description);
    if (currentRel.targetDate) parts.push('Target: ' + fmtDate(currentRel.targetDate + 'T00:00:00Z'));
    relDetail.innerHTML = parts.join('<br>');
  } else if (relName) {
    relName.textContent = 'All Requirements';
    if (relDetail) relDetail.textContent = 'No release plan defined';
  }

  /* Failed VC list in Test Results card */
  const failList = document.getElementById('hero-failed-list');
  if (failList && s.failed > 0) {
    const failedVCs = (REPORT.requirements || []).filter(r => r.status === 'fail');
    failList.innerHTML = failedVCs.map(r =>
      '<div style="color:var(--fail)">&#10007; <strong>' + esc(r.vc_id) + '</strong> — ' + esc(r.title) + '</div>'
    ).join('');
  }

  /* Blockers list */
  const bl = document.getElementById('hero-blockers');
  if (bl) {
    const lines = [];
    if (s.failed > 0) {
      const ids = (REPORT.requirements || []).filter(r => r.status === 'fail').map(r => r.vc_id).join(', ');
      lines.push('<span style="color:var(--fail)">&#10007; ' + s.failed + ' test failure' + (s.failed > 1 ? 's' : '') + '</span>');
    }
    if (s.drifted_vcs > 0) {
      lines.push('<span style="color:var(--drifted)">&#8635; ' + s.drifted_vcs + ' criteria drifted</span>');
    }
    if (s.uncovered_vcs > 0) {
      lines.push('<span style="color:var(--uncovered)">&#8212; ' + s.uncovered_vcs + ' uncovered</span>');
    }
    if (s.orphaned_tests > 0) {
      lines.push('<span style="color:var(--orphaned)">? ' + s.orphaned_tests + ' orphaned</span>');
    }
    bl.innerHTML = lines.join('<br>');
  }

  /* Bar legend */
  const legend = document.getElementById('hero-bar-legend');
  if (legend) {
    const parts = [];
    if (s.passed) parts.push('<span style="color:var(--pass)">&#9632;</span> ' + s.passed + ' passed');
    if (s.failed) parts.push('<span style="color:var(--fail)">&#9632;</span> ' + s.failed + ' failed');
    if (s.drifted_vcs) parts.push('<span style="color:var(--drifted)">&#9632;</span> ' + s.drifted_vcs + ' drifted');
    if (s.uncovered_vcs) parts.push('<span style="color:var(--uncovered)">&#9632;</span> ' + s.uncovered_vcs + ' uncovered');
    if (s.manual) parts.push('<span style="color:var(--manual)">&#9632;</span> ' + s.manual + ' manual');
    if (s.deferred_vcs) parts.push('<span style="color:var(--deferred)">&#9632;</span> ' + s.deferred_vcs + ' deferred');
    legend.innerHTML = parts.join(' &nbsp; ');
  }
})();

/* Item 6: Human-readable timestamp */
(function() {
  const el = document.getElementById('hero-timestamp');
  if (el && REPORT && REPORT.generated_at) el.textContent = 'Generated: ' + fmtDate(REPORT.generated_at);
})();

/* Tab failure indicator dots */
(function() {
  if (!REPORT || !REPORT.summary) return;
  const s = REPORT.summary;
  function addDot(tabId, cls) {
    const tab = document.getElementById(tabId);
    if (tab && !tab.querySelector('.tab-dot')) {
      const dot = document.createElement('span');
      dot.className = 'tab-dot ' + cls;
      tab.appendChild(dot);
    }
  }
  /* Summary tab: red if no-go */
  if (s.failed > 0 || s.uncovered_vcs > 0 || s.drifted_vcs > 0) addDot('tab-summary', 'dot-fail');
  /* Gates tab: red if any gate failed */
  if (TRACEABILITY && !TRACEABILITY.overall_pass) addDot('tab-gates', 'dot-fail');
  /* Traceability tab: red if failures, orange if uncovered */
  if (s.failed > 0) addDot('tab-traceability', 'dot-fail');
  else if (s.uncovered_vcs > 0 || s.drifted_vcs > 0) addDot('tab-traceability', 'dot-warn');
  /* Tests tab: red if any failed */
  if (s.failed > 0) addDot('tab-tests', 'dot-fail');
  /* Cyber tab: red if critical vulns */
  if (GRYPE && GRYPE.matches && GRYPE.matches.some(m => (m.vulnerability || {}).severity === 'Critical')) addDot('tab-security', 'dot-fail');
  else if (GRYPE && GRYPE.matches && GRYPE.matches.length > 0) addDot('tab-security', 'dot-warn');
})();
</script>
</body>
</html>
