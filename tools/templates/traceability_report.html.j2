      <!-- Story 3: Blockers (click → Quality Gates tab) -->
      <div class="hero-card" onclick="switchTab('gates')" style="background:{% if summary.failed > 0 or summary.uncovered_vcs > 0 or summary.drifted_vcs > 0 %}#fef2f2{% else %}#f0fdf4{% endif %};border-radius:8px;padding:16px;border:1px solid {% if summary.failed > 0 or summary.uncovered_vcs > 0 or summary.drifted_vcs > 0 %}#fecaca{% else %}#bbf7d0{% endif %};cursor:pointer;transition:all 0.15s" onmouseenter="this.style.opacity='0.9'" onmouseleave="this.style.opacity='1'">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
          <span style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted)">Blockers</span>
          <span style="font-size:0.75rem;color:var(--blue-ng)">View Gates &#8250;</span>
        </div>
        {% set blocker_count = summary.failed + summary.uncovered_vcs + summary.drifted_vcs + summary.orphaned_tests %}
        {% if blocker_count == 0 %}
        <div style="font-size:1.4rem;font-weight:700;color:var(--pass)">&#10003; None</div>
        <div style="font-size:0.85rem;color:var(--text-muted);margin-top:4px">All quality gates passed</div>
        {% else %}
        <div style="font-size:1.8rem;font-weight:700;color:var(--fail)">{{ blocker_count }}</div>
        <div style="font-size:0.82rem;line-height:1.6;margin-top:4px" id="hero-blockers"></div>
        {% endif %}
      </div>

    </div>

    <!-- Full breakdown bar -->
    <div style="margin-top:16px">
      <div class="cov-label">
        <span>All {{ summary.total_vcs }} Verification Criteria</span>
        <span id="hero-bar-legend" style="font-size:0.75rem"></span>
      </div>
      <div class="cov-bar" style="display:flex;height:10px;border-radius:5px;overflow:hidden;border:1px solid var(--border);background:#E8F4FB">
        {% if summary.total_vcs > 0 %}
        {% set tw = summary.total_vcs %}
        {% if summary.passed > 0 %}<div style="width:{{ (summary.passed/tw*100)|round(1) }}%;background:var(--pass)" title="Passed: {{ summary.passed }}"></div>{% endif %}
        {% if summary.failed > 0 %}<div style="width:{{ (summary.failed/tw*100)|round(1) }}%;background:var(--fail)" title="Failed: {{ summary.failed }}"></div>{% endif %}
        {% if summary.drifted_vcs > 0 %}<div style="width:{{ (summary.drifted_vcs/tw*100)|round(1) }}%;background:var(--drifted)" title="Drifted: {{ summary.drifted_vcs }}"></div>{% endif %}
        {% if summary.uncovered_vcs > 0 %}<div style="width:{{ (summary.uncovered_vcs/tw*100)|round(1) }}%;background:var(--uncovered)" title="Uncovered: {{ summary.uncovered_vcs }}"></div>{% endif %}
        {% if summary.manual > 0 %}<div style="width:{{ (summary.manual/tw*100)|round(1) }}%;background:var(--manual)" title="Manual: {{ summary.manual }}"></div>{% endif %}
        {% if summary.deferred_vcs is defined and summary.deferred_vcs > 0 %}<div style="width:{{ (summary.deferred_vcs/tw*100)|round(1) }}%;background:var(--deferred)" title="Deferred: {{ summary.deferred_vcs }}"></div>{% endif %}
        {% endif %}
      </div>
