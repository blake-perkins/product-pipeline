<!-- ======== DATA INJECTION ======== -->
<script>
const REPORT = {{ report_json }};
const REQUIREMENTS = {{ requirements_json }};
const BEHAVE = {{ behave_json }};
const TRACEABILITY = {{ traceability_json }};
const SBOM = {{ sbom_json }};
const GRYPE = {{ grype_json }};
const RELEASE_PLAN = {{ release_plan_json }};
</script>

<script>
/* ================================================================
   TAB NAVIGATION
   ================================================================ */
function switchTab(tabName) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  const btn = document.querySelector('[data-tab="' + tabName + '"]');
  if (btn) btn.classList.add('active');
  const panel = document.getElementById('panel-' + tabName);
  if (panel) { panel.classList.add('active'); panel.scrollIntoView({behavior:'smooth', block:'start'}); }
}
document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => switchTab(btn.dataset.tab));
});

/* ================================================================
   HELPERS
   ================================================================ */
function esc(s) { const d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }
const VALID_STATUSES = ['pass','fail','uncovered','drifted','manual','orphaned','stub','deferred'];
const STATUS_ICONS = {pass:'\u2713',fail:'\u2717',uncovered:'\u2014',drifted:'\u21BB',manual:'\u270B',orphaned:'?',stub:'\u2014',deferred:'\u23F1'};
function badgeFor(status) {
  const cls = VALID_STATUSES.includes(status) ? status : 'manual';
  const icon = STATUS_ICONS[cls] || '';
  return '<span class="badge b-' + cls + '">' + icon + ' ' + esc(status) + '</span>';
}
function fmtDur(s) { return s != null ? (s < 1 ? (s*1000).toFixed(0) + 'ms' : s.toFixed(2) + 's') : ''; }
/* Word-level diff for drifted criteria */
function wordDiff(oldText, newText) {
  if (!oldText || !newText) return null;
  const oldWords = oldText.split(/(\s+)/);
  const newWords = newText.split(/(\s+)/);
  /* Simple LCS-based word diff */
  const m = oldWords.length, n = newWords.length;
  const dp = Array.from({length: m+1}, () => new Array(n+1).fill(0));
  for (let i = 1; i <= m; i++)
    for (let j = 1; j <= n; j++)
      dp[i][j] = oldWords[i-1] === newWords[j-1] ? dp[i-1][j-1]+1 : Math.max(dp[i-1][j], dp[i][j-1]);
  /* Backtrack to build diff */
  const result = [];
  let i = m, j = n;
  while (i > 0 || j > 0) {
    if (i > 0 && j > 0 && oldWords[i-1] === newWords[j-1]) {
      result.unshift({type:'same', text:oldWords[i-1]});
      i--; j--;
    } else if (j > 0 && (i === 0 || dp[i][j-1] >= dp[i-1][j])) {
      result.unshift({type:'add', text:newWords[j-1]});
      j--;
    } else {
      result.unshift({type:'del', text:oldWords[i-1]});
      i--;
    }
  }
  return result;
}
function renderDiff(diffTokens) {
  return diffTokens.map(t => {
    if (t.type === 'add') return '<span style="background:#d4edda;color:#155724;padding:1px 2px;border-radius:2px;text-decoration:none">' + esc(t.text) + '</span>';
    if (t.type === 'del') return '<span style="background:#f8d7da;color:#721c24;padding:1px 2px;border-radius:2px;text-decoration:line-through">' + esc(t.text) + '</span>';
    return esc(t.text);
  }).join('');
}

/* Build lookup: vcId -> gate B item for drift data */
const driftLookup = {};
if (TRACEABILITY && TRACEABILITY.gate_b && TRACEABILITY.gate_b.items) {
  TRACEABILITY.gate_b.items.forEach(item => {
    const id = item.verificationCriteriaId || item.vc_id || '';
    if (id) driftLookup[id] = item;
  });
}

/* Semver compare: returns -1 if a<b, 0 if a==b, 1 if a>b */
function semverCmp(a, b) {
  if (!a || !b) return 0;
  const pa = a.split('.').map(Number), pb = b.split('.').map(Number);
  for (let i = 0; i < 3; i++) {
    if ((pa[i]||0) < (pb[i]||0)) return -1;
    if ((pa[i]||0) > (pb[i]||0)) return 1;
  }
  return 0;
}

/* Get current product version from the release plan */
function getCurrentVersion() {
  if (RELEASE_PLAN && RELEASE_PLAN.currentVersion) return RELEASE_PLAN.currentVersion;
  return null;
}
const CURRENT_VERSION = getCurrentVersion();

function isReleasedVersion(version) {
  if (!CURRENT_VERSION || !version) return false;
  return semverCmp(version, CURRENT_VERSION) < 0;
}

function isCurrentVersion(version) {
  if (!CURRENT_VERSION || !version) return false;
  return semverCmp(version, CURRENT_VERSION) === 0;
}

function fmtDate(iso) {
  if (!iso) return '\u2014';
  try {
    const d = new Date(iso);
    if (isNaN(d)) return iso;
    const now = new Date();
    const diffMs = now - d;
    if (diffMs > 0 && diffMs < 86400000) {
      const mins = Math.floor(diffMs / 60000);
      if (mins < 1) return 'Just now';
      if (mins < 60) return mins + ' minute' + (mins > 1 ? 's' : '') + ' ago';
      const hrs = Math.floor(mins / 60);
      return hrs + ' hour' + (hrs > 1 ? 's' : '') + ' ago';
    }
    return d.toLocaleDateString(undefined, {year:'numeric',month:'long',day:'numeric'}) + ' at ' + d.toLocaleTimeString(undefined, {hour:'2-digit',minute:'2-digit'});
  } catch(e) { return iso; }
}

/* Build a lookup: reqId -> full requirement object from REQUIREMENTS */
const reqLookup = {};
if (REQUIREMENTS && REQUIREMENTS.requirements) {
  REQUIREMENTS.requirements.forEach(r => { reqLookup[r.requirementId] = r; });
}

/* Build behave lookup: feature name -> feature object with full steps */
const behaveLookup = {};
const behaveFeatures = Array.isArray(BEHAVE) ? BEHAVE : (BEHAVE && BEHAVE.features ? BEHAVE.features : []);
behaveFeatures.forEach(f => {
  const tags = (f.tags || []).map(t => typeof t === 'string' ? t : (t.name || ''));
  /* Index by feature name and by REQ/VC tags */
  behaveLookup[f.name] = f;
  tags.forEach(tag => {
    const clean = tag.replace(/^@/, '');
    behaveLookup[clean] = f;
  });
});

/* Find behave scenarios matching a given VC ID */
function findScenariosForVC(vcId, reqId, reportRow) {
  /* Don't look for scenarios if this VC is uncovered or drifted — there aren't real ones */
  if (reportRow && (reportRow.status === 'uncovered' || reportRow.status === 'drifted')) {
    return [];
  }
  const results = [];
  behaveFeatures.forEach(feat => {
    const fTags = (feat.tags || []).map(t => (typeof t === 'string' ? t : (t.name || '')).replace(/^@/, ''));
    (feat.elements || []).forEach(el => {
      if (el.keyword === 'Background') return;
      const sTags = (el.tags || []).map(t => (typeof t === 'string' ? t : (t.name || '')).replace(/^@/, ''));
      const allTags = [...fTags, ...sTags];
      const hasVC = allTags.some(t => t.replace(/^VC[:\-_]/i, '') === vcId);
      const hasReq = allTags.some(t => t.replace(/^REQ[:\-_]/i, '') === reqId);
      /* Match by: (1) explicit VC tag, or (2) scenario name from report */
      if (hasVC) {
        results.push({ scenario: el, featureName: feat.name, featureFile: feat.location || feat.filename || '' });
      } else if (hasReq && reportRow && reportRow.scenario_name && el.name === reportRow.scenario_name) {
        results.push({ scenario: el, featureName: feat.name, featureFile: feat.location || feat.filename || '' });
      }
    });
  });
  /* Last resort: req-level match when report confirms a test result exists */
  if (results.length === 0 && reportRow && reportRow.status === 'pass') {
    behaveFeatures.forEach(feat => {
      const fTags = (feat.tags || []).map(t => (typeof t === 'string' ? t : (t.name || '')).replace(/^@/, ''));
      const hasReq = fTags.some(t => t.replace(/^REQ[:\-_]/i, '') === reqId);
      if (hasReq) {
        (feat.elements || []).forEach(el => {
          if (el.keyword === 'Background') return;
          results.push({ scenario: el, featureName: feat.name, featureFile: feat.location || feat.filename || '' });
        });
      }
    });
  }
  return results;
}

/* ================================================================
   TAB 1: TRACEABILITY MATRIX
   ================================================================ */
function renderTraceability() {
  const container = document.getElementById('trace-accordion');
  if (!REPORT || !REPORT.requirements || !REPORT.requirements.length) {
    container.innerHTML = '<div class="empty-state"><div class="icon">&#128203;</div><h3>No Requirements Data</h3><p>No traceability data is available for this report.</p></div>';
    return;
  }
  /* Group report rows by requirement_id */
  const grouped = {};
  const reqOrder = [];
  REPORT.requirements.forEach(row => {
    if (!grouped[row.requirement_id]) { grouped[row.requirement_id] = []; reqOrder.push(row.requirement_id); }
    grouped[row.requirement_id].push(row);
  });

  let html = '';
  reqOrder.forEach(reqId => {
    const rows = grouped[reqId];
    const req = reqLookup[reqId] || {};
    const title = rows[0].title || req.title || '';
    const desc = req.description || '';
    const satisfiedBy = (req.satisfiedBy || []).join(', ');
    const tracesTo = (req.tracesTo || []).join(', ');

    /* Mini bar */
    const counts = { pass: 0, fail: 0, uncovered: 0, drifted: 0, manual: 0 };
    rows.forEach(r => { counts[r.status] = (counts[r.status] || 0) + 1; });
    const total = rows.length;
    let miniBar = '<div class="mini-bar">';
    ['pass','fail','uncovered','drifted','manual'].forEach(s => {
      if (counts[s]) miniBar += '<span style="width:' + (counts[s]/total*100) + '%;background:var(--' + s + ')"></span>';
    });
    miniBar += '</div>';

    const vcSummary = rows.length + ' VC' + (rows.length > 1 ? 's' : '');

    /* Worst-status determines the card's left-border color */
    const STATUS_PRIORITY = ['fail','drifted','uncovered','deferred','manual','pass'];
    let worstStatus = 'pass';
    rows.forEach(r => {
      if (STATUS_PRIORITY.indexOf(r.status) < STATUS_PRIORITY.indexOf(worstStatus)) worstStatus = r.status;
    });

    html += '<div class="req-card rc-' + worstStatus + '" data-req="' + reqId + '">';
    html += '<div class="req-header" onclick="toggleReq(this)">';
    html += '<span class="arrow">&#9654;</span>';
    html += '<span class="req-id">' + esc(reqId) + '</span>';
    html += '<span class="req-title">' + esc(title) + '</span>';
    html += miniBar;
    html += '<span class="vc-summary">' + vcSummary + '</span>';
    html += '</div>';

    html += '<div class="req-body">';
    if (desc) html += '<div class="req-desc">' + esc(desc);
    if (satisfiedBy) html += '<br><strong>Satisfied By:</strong> ' + esc(satisfiedBy);
    if (tracesTo) html += '<br><strong>Traces To:</strong> ' + esc(tracesTo);
    if (desc) html += '</div>';

    rows.forEach(row => {
      const vcId = row.vc_id || '';
      const scenarios = findScenariosForVC(vcId, reqId, row);

      html += '<div class="vc-row" data-status="' + row.status + '" data-method="' + esc(row.method) + '">';
      html += '<div class="vc-header" onclick="toggleVC(this)">';
      html += '<span class="arrow">&#9654;</span>';
      html += '<span class="vc-id">' + esc(vcId || reqId) + '</span>';
      html += '<span class="vc-method">' + esc(row.method) + '</span>';
      html += badgeFor(row.status);
      if (scenarios.length > 0) html += '<span style="font-size:0.75rem;color:var(--text-muted);margin-left:auto">(' + scenarios.length + ' scenario' + (scenarios.length > 1 ? 's' : '') + ')</span>';
      html += '<span class="vc-feature">' + esc(row.feature_file || '') + '</span>';
      html += '</div>';

      /* Criteria display — show diff for drifted VCs */
      if (row.status === 'drifted' && driftLookup[vcId]) {
        const drift = driftLookup[vcId];
        if (drift.oldCriteria && drift.newCriteria) {
          const diff = wordDiff(drift.oldCriteria, drift.newCriteria);
          html += '<div class="vc-criteria" style="font-style:normal">';
          html += '<div style="font-size:0.75rem;font-weight:600;color:var(--text-muted);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px">Criteria Changed</div>';
          html += '<div style="font-size:0.85rem;line-height:1.6">' + renderDiff(diff) + '</div>';
          html += '</div>';
        } else {
          if (row.criteria) html += '<div class="vc-criteria">' + esc(row.criteria) + '</div>';
        }
      } else if (row.criteria) {
        html += '<div class="vc-criteria">' + esc(row.criteria) + '</div>';
      }

      /* Action hint for non-pass statuses */
      const ACTION_HINTS = {
        uncovered: 'Action: Write a Gherkin scenario for this verification criteria, then re-run the pipeline.',
        drifted: 'Action: Review the changes above, update the scenario if needed, remove @REVIEW_REQUIRED, and run --update-baseline.',
        fail: 'Action: Investigate the test failure below. Fix the product code or update the scenario.',
      };
      if (row.status === 'deferred') {
        const targetRel = row.target_release || '';
        html += '<div style="padding:8px 14px;font-size:0.82rem;color:var(--deferred);border-top:1px solid #f0f0f0">Deferred to release <strong>' + esc(targetRel) + '</strong>. No action needed for the current release.</div>';
      } else if (ACTION_HINTS[row.status]) {
        html += '<div style="padding:8px 14px;font-size:0.82rem;color:var(--' + row.status + ');border-top:1px solid #f0f0f0">' + ACTION_HINTS[row.status] + '</div>';
      }

      html += '<div class="scenario-list">';
      if (scenarios.length === 0 && row.status !== 'uncovered' && row.status !== 'drifted' && row.status !== 'manual') {
        html += '<div class="scenario-item" style="color:var(--text-muted);font-style:italic">No matching scenarios found</div>';
      }
      scenarios.forEach(s => {
        html += '<div class="scenario-item">';
        html += '<div class="scenario-name"><span>' + esc(s.scenario.name) + '</span><span>' + badgeFor(getScenarioStatus(s.scenario)) + '</span></div>';
        (s.scenario.steps || []).forEach(step => {
          const kw = (step.keyword || '').trim().toLowerCase().replace(/\*/, 'and');
          const kwClass = ['given','when','then','and','but'].includes(kw) ? kw : 'and';
          const stepStatus = (step.result && step.result.status) || '';
          const dur = step.result ? step.result.duration : null;
          html += '<div class="step">';
          html += '<span class="step-status ' + stepStatus + '"></span>';
          html += '<span class="step-kw ' + kwClass + '">' + esc(step.keyword) + '</span>';
          html += '<span class="step-text">' + esc(step.name) + '</span>';
          html += '<span class="step-dur">' + fmtDur(dur) + '</span>';
          html += '</div>';
        });
        html += '</div>';
      });
      html += '</div>'; /* scenario-list */
      html += '</div>'; /* vm-row */
    });

    html += '</div>'; /* req-body */
    html += '</div>'; /* req-card */
  });

  /* Orphaned tests */
  if (REPORT.orphaned_tests && REPORT.orphaned_tests.length) {
    html += '<h3 style="margin:20px 0 8px;color:var(--orphaned)">Orphaned Tests</h3>';
    html += '<p style="font-size:0.85rem;color:var(--text-muted);margin-bottom:12px">These scenarios reference requirements or verification criteria that no longer exist in the model. They should be removed or reassigned.</p>';
    REPORT.orphaned_tests.forEach(o => {
      const reqIds = (o.orphaned_req_ids || []).join(', ');
      const vcIds = (o.orphaned_vc_ids || o.orphaned_vm_ids || []).join(', ');
      const file = o.feature_file || '';
      const name = o.name || file || 'Unknown scenario';
      html += '<div class="req-card" style="border-color:var(--orphaned)">';
      html += '<div class="req-header" style="cursor:default">';
      html += badgeFor('orphaned');
      html += '<span class="req-title" style="margin-left:8px">' + esc(name) + '</span>';
      html += '</div>';
      html += '<div class="req-body open" style="display:block;padding:12px 16px">';
      if (file) html += '<div style="margin-bottom:6px"><strong>Feature file:</strong> <code style="font-size:0.85rem">' + esc(file) + '</code></div>';
      if (reqIds) html += '<div style="margin-bottom:6px"><strong>References deleted requirement(s):</strong> <code style="font-size:0.85rem;color:var(--fail)">' + esc(reqIds) + '</code></div>';
      if (vcIds) html += '<div style="margin-bottom:6px"><strong>References deleted VC(s):</strong> <code style="font-size:0.85rem;color:var(--fail)">' + esc(vcIds) + '</code></div>';
      html += '<div style="font-size:0.85rem;color:var(--text-muted);margin-top:8px"><strong>Action required:</strong> Delete this feature file or update its tags to reference a valid requirement.</div>';
      html += '</div>';
      html += '</div>';
    });
  }

  container.innerHTML = html;
}

function getScenarioStatus(scenario) {
  const steps = scenario.steps || [];
  for (let i = 0; i < steps.length; i++) {
    const st = steps[i].result ? steps[i].result.status : '';
    if (st === 'failed' || st === 'undefined') return 'fail';
  }
  return 'pass';
}

function toggleReq(el) {
  const body = el.nextElementSibling;
  const arrow = el.querySelector('.arrow');
  body.classList.toggle('open');
  arrow.classList.toggle('open');
}

function toggleVC(el) {
  /* Toggle the scenario-list (skip criteria div if present) */
  let sibling = el.nextElementSibling;
  while (sibling && !sibling.classList.contains('scenario-list')) sibling = sibling.nextElementSibling;
  if (sibling) {
    sibling.classList.toggle('open');
    el.querySelector('.arrow').classList.toggle('open');
  }
}

/* Expand All / Collapse All */
function toggleAllReqs() {
  const bodies = document.querySelectorAll('.req-body');
  const btn = document.getElementById('btn-expand-all');
  const openCount = Array.from(bodies).filter(b => b.classList.contains('open')).length;
  /* Collapse only if MORE THAN HALF are open — prevents collapsing when navigateToVC opened just one */
  const shouldCollapse = openCount > bodies.length / 2;
  bodies.forEach(b => { shouldCollapse ? b.classList.remove('open') : b.classList.add('open'); });
  document.querySelectorAll('.req-header .arrow').forEach(a => { shouldCollapse ? a.classList.remove('open') : a.classList.add('open'); });
  if (btn) btn.textContent = shouldCollapse ? 'Expand All' : 'Collapse All';
}

/* Navigate from Gate item to Traceability Matrix */
function navigateToVC(reqId, vcId, isOrphan, orphanKey) {
  /* Switch to Traceability tab */
  switchTab('traceability');

  /* Clear filters so the target card is visible */
  ['f-status', 'f-method', 'f-search'].forEach(id => {
    const el = document.getElementById(id);
    if (el) { el.tagName === 'SELECT' ? el.value = 'all' : (el.value = ''); }
  });
  applyFilters();

  /* Collapse all previously open cards so only the target is expanded */
  document.querySelectorAll('.req-body.open').forEach(b => b.classList.remove('open'));
  document.querySelectorAll('.req-header .arrow.open').forEach(a => a.classList.remove('open'));
  /* Clear any previous highlights */
  document.querySelectorAll('.flash-highlight').forEach(el => el.classList.remove('flash-highlight'));

  function flashHighlight(el) {
    /* Walk up to the .req-card if we're on a child element */
    let card = el.closest ? el.closest('.req-card') : el;
    if (card) card.classList.add('flash-highlight');
    el.scrollIntoView({ behavior: 'smooth', block: 'center' });
    setTimeout(() => { if (card) card.classList.remove('flash-highlight'); }, 2500);
  }

  /* For orphaned items, find the orphaned card directly */
  if (isOrphan) {
    const searchKey = orphanKey || reqId || vcId;
    const allCards = document.querySelectorAll('#trace-accordion .req-card');
    let found = null;
    allCards.forEach(card => {
      if (card.querySelector('.badge.b-orphaned') && (
        !searchKey || card.textContent.includes(searchKey)
      )) {
        found = card;
      }
    });
    if (found) {
      flashHighlight(found);
    } else {
      /* Fallback: scroll to Orphaned Tests heading */
      document.querySelectorAll('#trace-accordion h3').forEach(h => {
        if (h.textContent.includes('Orphaned')) h.scrollIntoView({ behavior: 'smooth', block: 'center' });
      });
    }
    return;
  }

  /* Find and expand the requirement card */
  const cards = document.querySelectorAll('.req-card');
  let targetCard = null;
  cards.forEach(card => {
    if (card.getAttribute('data-req') === reqId) targetCard = card;
  });

  if (targetCard) {
    /* Open the req-body if closed */
    const body = targetCard.querySelector('.req-body');
    const arrow = targetCard.querySelector('.req-header .arrow');
    if (body && !body.classList.contains('open')) {
      body.classList.add('open');
      if (arrow) arrow.classList.add('open');
    }

    /* Find the VC row and highlight it */
    let targetVC = null;
    targetCard.querySelectorAll('.vc-row').forEach(vr => {
      const vcHeader = vr.querySelector('.vc-id');
      if (vcHeader && vcHeader.textContent.trim() === vcId) targetVC = vr;
    });

    flashHighlight(targetVC || targetCard);
  }
}

/* Filters */
['f-status','f-method','f-search'].forEach(id => {
  const el = document.getElementById(id);
  if (el) el.addEventListener(el.tagName === 'SELECT' ? 'change' : 'input', applyFilters);
});

function applyFilters() {
  const status = document.getElementById('f-status').value;
  const method = document.getElementById('f-method').value;
  const search = document.getElementById('f-search').value.toLowerCase();

  document.querySelectorAll('.req-card').forEach(card => {
    /* Search only matches against req header (ID + title) and VC header (VC ID) */
    const headerText = (card.querySelector('.req-header') || {}).textContent || '';
    const cardMatchesSearch = !search || headerText.toLowerCase().includes(search);

    const vmRows = card.querySelectorAll('.vc-row');

    /* Orphaned cards have no VC rows — only filter by search */
    if (vmRows.length === 0) {
      card.style.display = cardMatchesSearch ? '' : 'none';
      return;
    }

    let anyVisible = false;
    vmRows.forEach(vr => {
      const s = vr.getAttribute('data-status');
      const m = vr.getAttribute('data-method');
      const vmHeaderText = (vr.querySelector('.vc-header') || {}).textContent || '';
      const vmMatchesSearch = !search || vmHeaderText.toLowerCase().includes(search) || cardMatchesSearch;
      let show = true;
      if (status !== 'all' && s !== status) show = false;
      if (method !== 'all' && m !== method) show = false;
      if (!vmMatchesSearch) show = false;
      vr.style.display = show ? '' : 'none';
      if (show) anyVisible = true;
    });
    card.style.display = anyVisible ? '' : 'none';
  });
  /* Show count of visible results */
  const allCards = document.querySelectorAll('.req-card[data-req]');
  const visibleCards = document.querySelectorAll('.req-card[data-req]:not([style*="none"])');
  let countEl = document.getElementById('filter-count');
  if (!countEl) {
    countEl = document.createElement('div');
    countEl.id = 'filter-count';
    countEl.style.cssText = 'font-size:0.82rem;color:var(--text-muted);margin-bottom:8px';
    const accordion = document.getElementById('trace-accordion');
    if (accordion) accordion.parentNode.insertBefore(countEl, accordion);
  }
  if (status !== 'all' || method !== 'all' || search) {
    countEl.textContent = 'Showing ' + visibleCards.length + ' of ' + allCards.length + ' requirements';
    countEl.style.display = '';
  } else {
    countEl.style.display = 'none';
  }

  /* Show empty state if all cards are hidden */
  let noResults = document.getElementById('filter-empty-state');
  const anyCards = visibleCards.length > 0;
  if (!anyCards && (status !== 'all' || method !== 'all' || search)) {
    if (!noResults) {
      noResults = document.createElement('div');
      noResults.id = 'filter-empty-state';
      noResults.className = 'empty-state';
      noResults.innerHTML = '<h3>No matching results</h3><p>Try adjusting your filters or search term.</p>';
      document.getElementById('trace-accordion').appendChild(noResults);
    }
    noResults.style.display = '';
  } else if (noResults) {
    noResults.style.display = 'none';
  }

  /* Search highlight: mark matching text in visible req-id and req-title spans */
  document.querySelectorAll('#trace-accordion mark.search-hl').forEach(m => {
    const parent = m.parentNode;
    parent.replaceChild(document.createTextNode(m.textContent), m);
    parent.normalize();
  });
  if (search) {
    document.querySelectorAll('.req-card:not([style*="none"]) .req-id, .req-card:not([style*="none"]) .req-title, .vc-row:not([style*="none"]) .vc-id').forEach(el => {
      const text = el.textContent;
      const idx = text.toLowerCase().indexOf(search);
      if (idx >= 0) {
        el.innerHTML = esc(text.substring(0, idx)) + '<mark class="search-hl">' + esc(text.substring(idx, idx + search.length)) + '</mark>' + esc(text.substring(idx + search.length));
      }
    });
  }
}

/* ================================================================
   TAB: CYBER
   ================================================================ */
function renderSecurity() {
  const container = document.getElementById('security-content');

  if (!SBOM && !GRYPE) {
    container.innerHTML = '<div class="empty-state">' +
      '<div class="icon">&#128274;</div>' +
      '<h3>Cyber Scan Data Not Included</h3>' +
      '<p>Software Bill of Materials (SBOM) and vulnerability scan results are generated<br>by the production Jenkins pipeline using Syft and Grype.</p>' +
      '<p style="margin-top:8px;font-size:0.85rem;color:var(--text-muted)">This report was generated without cyber scan data. When available,<br>this tab will show a full component inventory and vulnerability analysis.</p>' +
      '</div>';
    return;
  }

  let html = '';
  const matches = (GRYPE && GRYPE.matches) || [];
  const components = (SBOM && SBOM.components) || [];

  /* ---- #3 Policy compliance banner ---- */
  if (GRYPE) {
    const hasCritical = matches.some(m => (m.vulnerability || {}).severity === 'Critical');
    const hasHigh = matches.some(m => (m.vulnerability || {}).severity === 'High');
    if (hasCritical) {
      html += '<div style="padding:14px 20px;border-radius:8px;background:var(--fail);color:#fff;font-weight:700;font-size:1rem;margin-bottom:20px;display:flex;align-items:center;gap:12px">';
      html += '<span style="font-size:1.4rem">\u2717</span> POLICY: FAIL \u2014 Critical vulnerabilities detected. Deployment blocked per security policy.';
      html += '</div>';
    } else if (hasHigh) {
      html += '<div style="padding:14px 20px;border-radius:8px;background:var(--drifted);color:#333;font-weight:700;font-size:1rem;margin-bottom:20px;display:flex;align-items:center;gap:12px">';
      html += '<span style="font-size:1.4rem">\u26A0</span> POLICY: WARNING \u2014 High severity vulnerabilities found. Review required before deployment.';
      html += '</div>';
    } else if (matches.length === 0) {
      html += '<div style="padding:14px 20px;border-radius:8px;background:var(--pass);color:#fff;font-weight:700;font-size:1rem;margin-bottom:20px;display:flex;align-items:center;gap:12px">';
      html += '<span style="font-size:1.4rem">\u2713</span> POLICY: PASS \u2014 No vulnerabilities detected.';
      html += '</div>';
    } else {
      html += '<div style="padding:14px 20px;border-radius:8px;background:var(--pass);color:#fff;font-weight:700;font-size:1rem;margin-bottom:20px;display:flex;align-items:center;gap:12px">';
      html += '<span style="font-size:1.4rem">\u2713</span> POLICY: PASS \u2014 ' + matches.length + ' vulnerability(s) found, none above threshold.';
      html += '</div>';
    }
  }

  /* ---- Severity breakdown cards ---- */
  if (GRYPE) {
    const sevCounts = { Critical: 0, High: 0, Medium: 0, Low: 0, Negligible: 0 };
    let withFix = 0, noFix = 0;
    matches.forEach(m => {
      const sev = (m.vulnerability && m.vulnerability.severity) || 'Unknown';
      if (sevCounts[sev] !== undefined) sevCounts[sev]++;
      const fix = m.vulnerability && m.vulnerability.fix;
      const fixVersions = fix && fix.versions ? fix.versions : [];
      if (fixVersions.length > 0) withFix++; else noFix++;
    });

    html += '<h2 class="section-title" style="margin-top:0">Vulnerability Summary</h2>';
    html += '<div class="sev-cards">';
    ['Critical','High','Medium','Low','Negligible'].forEach(s => {
      html += '<div class="sev-card sev-' + s.toLowerCase() + '"><div class="sev-val">' + sevCounts[s] + '</div><div class="sev-lbl">' + s + '</div></div>';
    });
    html += '</div>';

    /* ---- #2 Fix availability summary ---- */
    html += '<div style="display:flex;gap:16px;margin:12px 0 20px;font-size:0.9rem">';
    html += '<span style="color:var(--pass);font-weight:600">\u2713 ' + withFix + ' with fix available</span>';
    html += '<span style="color:var(--fail);font-weight:600">\u2717 ' + noFix + ' no fix available</span>';
    html += '<span style="color:var(--text-muted)">' + matches.length + ' total</span>';
    html += '</div>';

    /* ---- #7 Severity filter + #8 CVE links + #4 CVE year + #6 CSV export ---- */
    if (matches.length) {
      html += '<h2 class="section-title">Vulnerability Details</h2>';
      html += '<div class="filter-row">';
      html += '<label>Severity:</label>';
      html += '<select id="vuln-sev-filter" onchange="filterVulns()">';
      html += '<option value="all">All</option>';
      ['Critical','High','Medium','Low','Negligible'].forEach(s => {
        html += '<option value="' + s + '">' + s + '</option>';
      });
      html += '</select>';
      html += '<label style="margin-left:8px">Search:</label>';
      html += '<input type="text" id="vuln-search" placeholder="Filter by CVE, package..." oninput="filterVulns()">';
      html += '<button class="btn btn-secondary" style="padding:4px 14px;font-size:0.8rem;margin-left:auto" onclick="exportVulnCSV()">Download CSV</button>';
      html += '</div>';
      html += '<div class="table-scroll"><table class="data-table" id="vuln-table"><thead><tr>';
      html += '<th>CVE ID</th><th>Year</th><th>Severity</th><th>Package</th><th>Version</th><th>Fix Available</th><th>Description</th>';
      html += '</tr></thead><tbody>';
      matches.forEach(m => {
        const v = m.vulnerability || {};
        const a = m.artifact || {};
        const fixVersions = v.fix && v.fix.versions ? v.fix.versions : [];
        const fixCell = fixVersions.length > 0
          ? '<span style="color:var(--pass);font-weight:600">\u2713 ' + esc(fixVersions.join(', ')) + '</span>'
          : '<span style="color:var(--fail);font-weight:600">\u2717 No fix</span>';
        /* #4 Extract year from CVE ID */
        const cveYear = (v.id || '').match(/CVE-(\d{4})/);
        const yearStr = cveYear ? cveYear[1] : '\u2014';
        /* #8 CVE link */
        const cveLink = '<span style="font-family:monospace" title="' + esc(v.description || '') + '">' + esc(v.id) + '</span>';
        html += '<tr data-severity="' + esc(v.severity || '') + '">';
        html += '<td>' + cveLink + '</td>';
        html += '<td style="text-align:center">' + yearStr + '</td>';
        html += '<td><span class="badge" style="background:var(--sev-' + (v.severity||'negligible').toLowerCase() + ');color:#fff">' + esc(v.severity) + '</span></td>';
        html += '<td>' + esc(a.name) + '</td>';
        html += '<td>' + esc(a.version) + '</td>';
        html += '<td>' + fixCell + '</td>';
        html += '<td style="max-width:300px;font-size:0.8rem">' + esc(v.description || '').substring(0, 200) + '</td>';
        html += '</tr>';
      });
      html += '</tbody></table></div>';
    } else {
      html += '<p style="color:var(--pass);font-weight:600;margin:12px 0">\u2713 No vulnerabilities found.</p>';
    }
  }

  /* ---- #5 SBOM with dependency type + component count ---- */
  if (SBOM) {
    html += '<h2 class="section-title">SBOM Component Inventory (' + components.length + ' components)</h2>';

    /* Group by type */
    const byType = {};
    components.forEach(c => {
      const t = c.type || 'unknown';
      byType[t] = (byType[t] || 0) + 1;
    });
    html += '<div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:12px">';
    Object.entries(byType).forEach(([t, count]) => {
      html += '<span style="font-size:0.82rem;padding:4px 10px;background:#f9fafb;border:1px solid #e9ecef;border-radius:12px">' + esc(t) + ': <strong>' + count + '</strong></span>';
    });
    html += '</div>';

    if (components.length) {
      /* Mark which components have vulnerabilities */
      const vulnPkgs = {};
      matches.forEach(m => {
        const a = m.artifact || {};
        const v = m.vulnerability || {};
        const key = a.name + '@' + a.version;
        if (!vulnPkgs[key]) vulnPkgs[key] = [];
        vulnPkgs[key].push(v.severity || 'Unknown');
      });

      html += '<div class="filter-row"><label>Search:</label><input type="text" id="sbom-search" placeholder="Filter components..." oninput="filterSBOM()"></div>';
      html += '<div class="table-scroll"><table class="data-table" id="sbom-table"><thead><tr>';
      html += '<th>Name</th><th>Version</th><th>Type</th><th>Vulnerabilities</th><th>PURL</th>';
      html += '</tr></thead><tbody>';
      components.forEach(c => {
        const key = c.name + '@' + c.version;
        const vulns = vulnPkgs[key] || [];
        let vulnCell = '<span style="color:var(--pass)">\u2713 None</span>';
        if (vulns.length > 0) {
          const worst = ['Critical','High','Medium','Low','Negligible'].find(s => vulns.includes(s)) || 'Unknown';
          vulnCell = '<span class="badge" style="background:var(--sev-' + worst.toLowerCase() + ');color:#fff">' + vulns.length + ' (' + worst + ')</span>';
        }
        html += '<tr><td><strong>' + esc(c.name) + '</strong></td><td>' + esc(c.version) + '</td><td>' + esc(c.type) + '</td><td>' + vulnCell + '</td><td style="font-size:0.75rem;word-break:break-all;color:var(--text-muted)">' + esc(c.purl || '') + '</td></tr>';
      });
      html += '</tbody></table></div>';
    }
  }

  container.innerHTML = html;
}

/* #7 Vulnerability filter */
function filterVulns() {
  const sev = (document.getElementById('vuln-sev-filter') || {}).value || 'all';
  const search = ((document.getElementById('vuln-search') || {}).value || '').toLowerCase();
  document.querySelectorAll('#vuln-table tbody tr').forEach(r => {
    const rowSev = r.getAttribute('data-severity') || '';
    const text = r.textContent.toLowerCase();
    let show = true;
    if (sev !== 'all' && rowSev !== sev) show = false;
    if (search && !text.includes(search)) show = false;
    r.style.display = show ? '' : 'none';
  });
}

/* #6 CSV export */
function exportVulnCSV() {
  if (!GRYPE || !GRYPE.matches) return;
  const rows = [['CVE ID','Severity','Package','Version','Fix Versions','Description']];
  GRYPE.matches.forEach(m => {
    const v = m.vulnerability || {};
    const a = m.artifact || {};
    const fix = v.fix && v.fix.versions ? v.fix.versions.join('; ') : '';
    rows.push([v.id || '', v.severity || '', a.name || '', a.version || '', fix, (v.description || '').replace(/"/g, '""')]);
  });
  const csv = rows.map(r => r.map(c => '"' + c + '"').join(',')).join('\n');
  const blob = new Blob([csv], { type: 'text/csv' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'vulnerabilities.csv';
  a.click();
  URL.revokeObjectURL(a.href);
}

function filterSBOM() {
  const q = (document.getElementById('sbom-search') || {}).value || '';
  const rows = document.querySelectorAll('#sbom-table tbody tr');
  const search = q.toLowerCase();
  rows.forEach(r => { r.style.display = r.textContent.toLowerCase().includes(search) ? '' : 'none'; });
}

/* ================================================================
   TAB 3: QUALITY GATES
   ================================================================ */
function renderGates() {
  const container = document.getElementById('gates-content');
  if (!TRACEABILITY) { container.innerHTML = '<div class="empty-state"><h3>No traceability data available</h3></div>'; return; }

  const gates = [
    { key: 'gate_a', name: 'Gate A — Coverage', desc: 'Ensures every verification criteria has at least one Gherkin scenario. Generates stubs for any gaps.' },
    { key: 'gate_b', name: 'Gate B — Drift Detection', desc: 'Detects when requirement verification criteria change between model versions. Flags scenarios for review.' },
    { key: 'gate_c', name: 'Gate C — Orphan Detection', desc: 'Finds test scenarios referencing requirements or VCs that no longer exist in the model.' },
  ];

  let html = '<div class="gate-cards">';
  gates.forEach(g => {
    const data = TRACEABILITY[g.key] || {};
    const passed = data.passed !== false;
    const items = data.items || [];
    const gateLabel = g.key === 'gate_a' ? 'A' : g.key === 'gate_b' ? 'B' : 'C';
    html += '<div class="gate-card ' + (passed ? 'gate-pass' : 'gate-fail') + '" data-gate="' + gateLabel + '">';
    html += '<div class="gate-title"><span class="gate-name">' + g.name + '</span>' + badgeFor(passed ? 'pass' : 'fail') + '</div>';
    html += '<div class="gate-desc">' + g.desc + '</div>';
    if (data.message) html += '<p style="font-size:0.85rem;margin-bottom:8px">' + esc(data.message) + '</p>';
    if (items.length === 0) {
      html += '<p style="color:var(--pass);font-size:0.85rem">No issues detected.</p>';
    }
    items.forEach(item => {
      const id = item.verificationCriteriaId || item.vc_id || item.requirementId || '';
      const reqId = item.requirementId || (id.match(/^(.*)-VC-\d+$/) || [])[1] || '';
      const isOrphan = g.key === 'gate_c';
      /* For orphans, pass the orphaned req/vc IDs so we can find the right card */
      const orphanKey = isOrphan ? ((item.orphanedReqIds || [])[0] || (item.orphanedVcIds || [])[0] || item.scenarioName || item.featureFile || '') : '';
      html += '<div class="gate-item" style="cursor:pointer" onclick="navigateToVC(\'' + esc(reqId) + '\',\'' + esc(id) + '\',' + isOrphan + ',\'' + esc(orphanKey) + '\')" title="Click to view in Traceability Matrix">';
      html += '<span class="gi-id" style="color:var(--blue-ng)">' + esc(id) + '</span> <span style="font-size:0.75rem;color:var(--text-muted)">&#x2197;</span>';
      if (item.method) html += ' <span style="font-size:0.8rem;color:var(--text-muted)">(' + esc(item.method) + ')</span>';
      if (item.title) html += '<div class="gi-detail">' + esc(item.title) + '</div>';
      if (item.stubGenerated) html += '<div class="gi-detail">Stub: ' + esc(item.stubGenerated) + '</div>';
      if (item.oldHash && item.newHash) html += '<div class="gi-detail">Hash changed: ' + esc(item.oldHash.substring(0,12)) + '... &rarr; ' + esc(item.newHash.substring(0,12)) + '...</div>';
      if (item.orphanedReqIds && item.orphanedReqIds.length) html += '<div class="gi-detail">Orphaned IDs: ' + item.orphanedReqIds.map(esc).join(', ') + '</div>';
      if (item.orphanedVmIds && item.orphanedVmIds.length) html += '<div class="gi-detail">Orphaned VC IDs: ' + item.orphanedVmIds.map(esc).join(', ') + '</div>';
      if (item.featureFile) html += '<div class="gi-detail">Feature: ' + esc(item.featureFile) + '</div>';
      html += '</div>';
    });
    html += '</div>';
  });
  html += '</div>';

  /* Overall */
  html += '<div style="margin-top:20px;text-align:center">';
  html += '<strong>Overall Pipeline: </strong>' + badgeFor(TRACEABILITY.overall_pass ? 'pass' : 'fail');
  html += '<span style="margin-left:8px;font-size:0.85rem;color:var(--text-muted)">';
  html += TRACEABILITY.requirements_total + ' requirements, ' + TRACEABILITY.vcs_total + ' VCs, ' + TRACEABILITY.features_scanned + ' features scanned';
  html += '</span></div>';

  container.innerHTML = html;
}

/* ================================================================
   TAB 4: TEST EXECUTION
   ================================================================ */
function renderTests() {
  const container = document.getElementById('tests-content');

  /* Filter out @manual / @STUB features — they aren't automated tests */
  function isManualFeature(feat) {
    const tags = (feat.tags || []).map(t => (typeof t === 'string' ? t : (t.name || '')).replace(/^@/, '').toLowerCase());
    return tags.includes('manual') || tags.includes('stub') || tags.includes('auto_generated');
  }
  const automatedFeatures = behaveFeatures.filter(f => !isManualFeature(f));

  if (!automatedFeatures.length) {
    container.innerHTML = '<div class="empty-state"><h3>No Behave test results available</h3></div>';
    return;
  }

  let totalScenarios = 0, totalSteps = 0, totalDur = 0, scenarioPassed = 0;
  automatedFeatures.forEach(f => {
    (f.elements || []).forEach(el => {
      if (el.keyword === 'Background') return;
      totalScenarios++;
      let passed = true;
      (el.steps || []).forEach(s => {
        totalSteps++;
        if (s.result) totalDur += (s.result.duration || 0);
        if (s.result && (s.result.status === 'failed' || s.result.status === 'undefined')) passed = false;
      });
      if (passed) scenarioPassed++;
    });
  });

  let html = '<div style="display:flex;gap:20px;flex-wrap:wrap;margin-bottom:16px">';
  html += '<div class="info-item"><div class="info-label">Features</div><div class="info-value">' + automatedFeatures.length + '</div></div>';
  html += '<div class="info-item"><div class="info-label">Scenarios</div><div class="info-value">' + totalScenarios + '</div></div>';
  html += '<div class="info-item"><div class="info-label">Steps</div><div class="info-value">' + totalSteps + '</div></div>';
  html += '<div class="info-item"><div class="info-label">Total Duration</div><div class="info-value">' + fmtDur(totalDur) + '</div></div>';
  html += '<div class="info-item"><div class="info-label">Pass Rate</div><div class="info-value" style="color:' + (scenarioPassed === totalScenarios ? 'var(--pass)' : 'var(--fail)') + '">' + (totalScenarios ? Math.round(scenarioPassed/totalScenarios*100) : 0) + '%</div></div>';
  html += '</div>';
  html += '<div class="filter-row" style="margin-bottom:16px">';
  html += '<label for="test-filter">Show:</label>';
  html += '<select id="test-filter" onchange="filterTests()">';
  html += '<option value="all">All Features</option>';
  html += '<option value="failed">Failures Only</option>';
  html += '<option value="passed">Passed Only</option>';
  html += '</select>';
  html += '<label style="margin-left:8px">Search:</label>';
  html += '<input type="text" id="test-search" placeholder="Filter by feature or scenario name..." oninput="filterTests()">';
  html += '</div>';

  automatedFeatures.forEach((feat, fi) => {
    const featureStatus = feat.status || 'passed';
    const scenarios = (feat.elements || []).filter(e => e.keyword !== 'Background');
    let featDur = 0;
    scenarios.forEach(sc => (sc.steps || []).forEach(s => { if (s.result) featDur += (s.result.duration || 0); }));

    html += '<div class="test-feature" data-status="' + featureStatus + '">';
    html += '<div class="test-feature-header" onclick="toggleTestFeature(this)">';
    html += '<span class="arrow">&#9654;</span>';
    html += '<span>' + esc(feat.name) + '</span>';
    html += '<span class="feat-dur">' + fmtDur(featDur) + '</span>';
    html += '<span class="feat-status">' + badgeFor(featureStatus === 'passed' ? 'pass' : 'fail') + '</span>';
    html += '</div>';
    html += '<div class="test-feature-body">';

    scenarios.forEach(sc => {
      const scStatus = getScenarioStatus(sc);
      let scDur = 0;
      (sc.steps || []).forEach(s => { if (s.result) scDur += (s.result.duration || 0); });

      html += '<div class="test-scenario">';
      html += '<div class="test-scenario-name"><span>' + esc(sc.name) + '</span><span>' + fmtDur(scDur) + ' ' + badgeFor(scStatus) + '</span></div>';
      (sc.steps || []).forEach(step => {
        const kw = (step.keyword || '').trim().toLowerCase().replace(/\*/, 'and');
        const kwClass = ['given','when','then','and','but'].includes(kw) ? kw : 'and';
        const stepStatus = (step.result && step.result.status) || '';
        const dur = step.result ? step.result.duration : null;
        html += '<div class="step">';
        html += '<span class="step-status ' + stepStatus + '"></span>';
        html += '<span class="step-kw ' + kwClass + '">' + esc(step.keyword) + '</span>';
        html += '<span class="step-text">' + esc(step.name) + '</span>';
        html += '<span class="step-dur">' + fmtDur(dur) + '</span>';
        html += '</div>';
        if (stepStatus === 'failed' && step.result.error_message) {
          html += '<div style="padding:4px 0 4px 80px;color:var(--fail);font-size:0.8rem;font-family:monospace;white-space:pre-wrap">' + esc(step.result.error_message) + '</div>';
        }
      });
      html += '</div>';
    });

    html += '</div></div>';
  });

  container.innerHTML = html;
}

function filterTests() {
  const filter = (document.getElementById('test-filter') || {}).value || 'all';
  const search = ((document.getElementById('test-search') || {}).value || '').toLowerCase();
  document.querySelectorAll('.test-feature').forEach(feat => {
    const status = feat.getAttribute('data-status') || '';
    const text = feat.textContent.toLowerCase();
    let show = true;
    if (filter === 'failed' && status !== 'failed') show = false;
    if (filter === 'passed' && status !== 'passed') show = false;
    if (search && !text.includes(search)) show = false;
    feat.style.display = show ? '' : 'none';
  });
}

function toggleTestFeature(el) {
  const body = el.nextElementSibling;
  body.classList.toggle('open');
  el.querySelector('.arrow').classList.toggle('open');
}

