{% set is_manual = vc.verificationMethod not in ["Test", "Demonstration"] -%}
{% if is_manual -%}
@REQ:{{ requirement.requirementId }} @manual @STUB @AUTO_GENERATED
{% else -%}
@REQ:{{ requirement.requirementId }} @STUB @AUTO_GENERATED
{% endif -%}
Feature: {{ vc.verificationId }} - {{ requirement.name }} ({{ vc.verificationMethod }})
  {{ requirement.description | default("No description provided.", true) }}

  Verification Method: {{ vc.verificationMethod }}
  Verification Criteria: {{ vc.verificationDescription | default("N/A", true) }}

  @VC:{{ vc.verificationId }}
  Scenario: Verify {{ vc.verificationId }} - {{ requirement.name }}
    Given the system is configured for {{ vc.verificationMethod | lower }} verification of "{{ requirement.requirementId }}"
    When the {{ vc.verificationMethod | lower }} verification is performed
    Then it should fail because it is not yet implemented
