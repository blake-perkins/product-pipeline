{% set is_manual = requirement.verification_method not in ["Test", "Demonstration"] -%}
{% if is_manual -%}
@REQ:{{ requirement.requirementId }} @manual @STUB @AUTO_GENERATED
{% else -%}
@REQ:{{ requirement.requirementId }} @STUB @AUTO_GENERATED
{% endif -%}
Feature: {{ requirement.requirementId }} - {{ requirement.title }}
  {{ requirement.description | default("No description provided.", true) }}

  Verification Method: {{ requirement.verification_method }}
  Verification Criteria: {{ requirement.verification_criteria | default("N/A", true) }}

  Scenario: Verify {{ requirement.requirementId }} - {{ requirement.title }}
    Given the system is configured for {{ requirement.verification_method | lower }} verification of "{{ requirement.requirementId }}"
    When the {{ requirement.verification_method | lower }} verification is performed
    Then it should fail because it is not yet implemented
